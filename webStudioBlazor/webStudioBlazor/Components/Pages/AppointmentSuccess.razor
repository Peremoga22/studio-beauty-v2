@page "/appointment-success"
@page "/appointment-success/{Id:int}"

@using webStudioBlazor.BL

@inject AppointmentNotifier _notification
@inject IConfiguration _configuration
@inject SeedService _seedService
@inject NavigationManager _navigationManager
@rendermode InteractiveServer

<section class="shine-appoint-success-page py-3">
    <div class="shine-appoint-success-inner">
        <div class="row justify-content-center g-0">
            <div class="col-12 col-lg-8 col-xl-6">
                <div class="card shine-appoint-success-card border-0 shadow-none text-center">
                    <div class="card-body p-4 p-md-5">
                        <span class="shine-appoint-success-badge">Успішно</span>
                        <h1 class="shine-appoint-success-title">Дякуємо! Запис створено</h1>
                        @if (!string.IsNullOrWhiteSpace(clientUser.ClientName))
                        {
                            <p class="shine-appoint-success-lead mb-0">
                                @clientUser.ClientName — ми зв’яжемося з вами для підтвердження деталей найближчим часом.
                            </p>
                        }
                        else
                        {
                            <p class="shine-appoint-success-lead mb-0">
                                Ми зв’яжемося з вами для підтвердження деталей найближчим часом.
                            </p>
                        }
                        <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center align-items-stretch align-items-sm-center mt-4 pt-1">
                            <a href="/"
                               class="shine-appoint-success-btn-outline text-decoration-none w-100 w-sm-auto">
                                На головну
                            </a>
                            <a href="/appointment-user"
                               class="shine-hero-btn shine-appoint-success-btn-primary text-decoration-none w-100 w-sm-auto">
                                Новий запис
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@code {
    [Parameter]
    public int Id { get; set; }

    private Appointment clientUser = new();
    private List<Master> masters = new();
    private List<Category> categories = new();
    private List<PageTherapy> pageTherapies = new();
    private string? DeepLink;
    private bool _didRun;

    protected override async Task OnInitializedAsync()
    {
        var appt = Id > 0 ? await _seedService.GetClientAppointmentId(Id) : null;
        clientUser = appt ?? new Appointment();
        masters = await _seedService.GetAllMasterListAsync();
        categories = await _seedService.GetAllCategoryListAsync();
        pageTherapies = await _seedService.GetAllPageTherapyListAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _didRun) return;
        _didRun = true;

        await EnsureLinkAndNotifyOnceAsync();
    }

    private async Task EnsureLinkAndNotifyOnceAsync()
    {
        if (Id <= 0)
        {
            return;
        }

        var botUsername = _configuration["Telegram:BotUsername"];
        var baseLink = _configuration["Telegram:BaseLink"];
        if (!string.IsNullOrWhiteSpace(botUsername) && !string.IsNullOrWhiteSpace(baseLink))
        {
            DeepLink = $"{baseLink.TrimEnd('/')}/{botUsername}?start={Id}";
        }

        await SendMessageAsync();
    }

    private async Task SendMessageAsync()
    {
        if (Id <= 0 || string.IsNullOrWhiteSpace(clientUser.ClientName))
        {
            return;
        }

        categories = await _seedService.GetAllCategoryListAsync();
        var therapyCards = await _seedService.GetAllTherapyCardListAsync();
        var category = categories.FirstOrDefault(c => c.Id == clientUser.CategoryId);
        var categoryName = category?.NameCategory;
        var procedure = therapyCards.FirstOrDefault(t => t.Id == clientUser.TherapyId);

        await _notification.NotifyNewAsync(
            clientName: clientUser.ClientName,
            phone: clientUser.ClientPhone,
            serviceName: categoryName ?? string.Empty,
            procedureName: procedure?.TitleCard ?? string.Empty,
            date: clientUser.AppointmentDate,
            time: clientUser.SetHour
        );
    }
}

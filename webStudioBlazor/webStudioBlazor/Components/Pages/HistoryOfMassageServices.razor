@page "/history-of-massage-services/{CurrentUserId}"
@inject SeedService _seedService

<section class="shine-history-page">
    <div class="shine-history-inner">
        <header class="shine-history-header text-center">
            <span class="shine-history-kicker">Масажна терапія</span>
            <h1 class="shine-history-title">Історія ваших масажних процедур</h1>
            <p class="shine-history-lead mb-0">
                Тут відображаються всі процедури, які ви проходили у нашій студії.
            </p>
        </header>

        <nav class="shine-history-breadcrumb mb-4" aria-label="Навігаційна стежка">
            <a href="/account/profile" class="shine-history-breadcrumb-link">Особистий кабінет</a>
            <span class="shine-history-breadcrumb-sep" aria-hidden="true">/</span>
            <span class="shine-history-breadcrumb-current">Масажна терапія — мої записи</span>
        </nav>

        @if (IsLoading)
        {
            <div class="shine-history-loading text-center py-5">
                <div class="spinner-border shine-history-spinner" role="status" aria-label="Завантаження">
                    <span class="visually-hidden">Завантаження…</span>
                </div>
            </div>
        }
        else if (massageHistory is null || !massageHistory.Any())
        {
            <div class="shine-history-empty text-center">
                <div class="shine-history-empty-card">
                    <i class="fa-solid fa-spa shine-history-empty-icon" aria-hidden="true"></i>
                    <p class="shine-history-empty-title mb-2">Записів поки немає</p>
                    <p class="shine-history-empty-text mb-0">
                        Після візиту до студії ваші процедури з’являться тут автоматично.
                    </p>
                    <a href="/appointment-user" class="shine-history-empty-cta text-decoration-none mt-4 d-inline-flex align-items-center justify-content-center">
                        Записатися онлайн
                    </a>
                </div>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var item in massageHistory.Where(a => a.CategoryId == 2))
                {
                    <div class="col-12 col-sm-6 col-lg-4">
                        <div class="card appointment-card border-0 h-100 shine-history-card">
                            <div class="position-relative shine-history-img-wrap shine-history-media">
                                <div class="ratio ratio-16x9">
                                    <lite-youtube class="shine-history-youtube"
                                                  videoid="@item.ImageUrl"
                                                  title="@item.ServiceName"></lite-youtube>
                                </div>
                            </div>
                            <div class="card-body d-flex flex-column p-4">
                                <h2 class="h5 fw-bold text-center shine-history-service-title mb-3">
                                    @item.ServiceName
                                </h2>
                                <p class="shine-history-meta mb-2">
                                    <i class="fa-solid fa-user-nurse me-2 opacity-75" aria-hidden="true"></i>
                                    Майстер: <span class="fw-semibold">@item.MasterFullName</span>
                                </p>
                                <p class="shine-history-meta mb-2">
                                    <i class="fa-regular fa-calendar me-2 opacity-75" aria-hidden="true"></i>
                                    @item.AppointmentDate.ToString("dd.MM.yyyy")
                                </p>
                                <p class="shine-history-description small mb-0 flex-grow-1">
                                    @item.Description
                                </p>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>

@code {
    [Parameter] public string CurrentUserId { get; set; } = string.Empty;

    private bool IsLoading = true;

    private List<AppointmentWithDetailsDto> massageHistory { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        massageHistory = await _seedService.GetAppointmentsByUserIdAsync(CurrentUserId);
        IsLoading = false;
    }
}

@page "/"


<!-- Головний контейнер -->
<div class="container-fluid p-0">

    <div class="px-2 px-md-3 pt-2">
        <ShineHero3DCarousel Slides="_heroSlides" />
    </div>

    <!-- ==== Послуги ==== -->
    <section class="shine-home-services position-relative">
        <div class="container py-5">
            <div class="section-title mb-5 text-center wow fadeInUp" data-wow-delay="0.2s">
                <div class="sub-style">
                    <h4 class="sub-title px-3 mb-0">Що ми пропонуємо</h4>
                </div>
                <h2 class="display-5 mb-3">Професійний догляд для вашої шкіри</h2>
                <p>У SHINE cosmetology by Lesia Zelinska ми поєднуємо сучасну косметологію, якісні препарати та турботу про кожного клієнта.</p>
            </div>

            <div class="row g-4 g-lg-5 justify-content-center">
                <!-- Косметологія -->
                <div class="col-md-6 col-lg-5 col-xl-4 wow fadeInUp d-flex" data-wow-delay="0.1s">
                    <div class="shine-home-service-card service-item w-100 d-flex flex-column">
                        <div class="shine-home-service-media position-relative flex-shrink-0">
                            <img src="img/foto36.jpeg" class="shine-home-service-img" alt="Косметологія" loading="lazy" decoding="async">
                        </div>
                        <div class="shine-home-service-body text-center p-4 flex-grow-1 d-flex flex-column">
                            <h5 class="mb-3">Косметологія</h5>
                            <p class="mb-4 flex-grow-1">Чиста і оксамитова шкіра для сучасних дівчат - це запорука успіху, краси і впевненості в собі.</p>
                            <a href="/cosmetology" class="btn-buy mt-auto align-self-center">Читати більше</a>
                        </div>
                    </div>
                </div>

                <!-- Масажна терапія -->
                <div class="col-md-6 col-lg-5 col-xl-4 wow fadeInUp d-flex" data-wow-delay="0.2s">
                    <div class="shine-home-service-card service-item w-100 d-flex flex-column">
                        <div class="shine-home-service-media position-relative flex-shrink-0">
                            <img src="img/foto45.jpeg" class="shine-home-service-img" alt="Масаж" loading="lazy" decoding="async">
                        </div>
                        <div class="shine-home-service-body text-center p-4 flex-grow-1 d-flex flex-column">
                            <h5 class="mb-3">Масажна терапія</h5>
                            <p class="mb-4 flex-grow-1">Відкрийте для себе світ релаксації та відновлення і здоров'я з нашою масажною терапією.</p>
                            <a href="/massage-therapy" class="btn-buy mt-auto align-self-center">Читати більше</a>
                        </div>
                    </div>
                </div>
          
            <!-- Манікюр -->
          @*   <div class="col-md-6 col-lg-4 col-xl-3 wow fadeInUp" data-wow-delay="0.2s">
                <div class="service-item rounded shadow">
                    <div style="height: 380px; overflow: hidden;">
                        <img src="img/podologia.png"
                             class="img-fluid w-100 h-100 rounded-top"
                             style="object-fit: cover;"
                             alt="Масаж"
                             loading="lazy"
                             decoding="async">
                    </div>

                    <div class="bg-light text-center p-4 rounded-bottom">
                        <h5 class="mb-3">Подологія</h5>
                        <p>Подологія — це медична галузь, що займається діагностикою, лікуванням і профілактикою захворювань стопи, нігтів.</p>
                        <a href="/manicure" class="btn-buy">Читати більше</a>
                    </div>
                </div>
            </div> *@
            </div>
        </div>
    </section>
    <!-- ==== Кінець Послуг ==== -->
    <!-- ==== Команда ==== -->
    <section class="shine-home-team position-relative">
        <div class="container py-5">
            <div class="section-title mb-5 text-center wow fadeInUp" data-wow-delay="0.1s">
                <div class="sub-style">
                    <h4 class="sub-title px-3 mb-0">Наша команда</h4>
                </div>
                <h2 class="display-5 mb-3">Послуги професійної косметологині</h2>
                <p>Відчуйте турботу про себе з професіоналом SHINE. Результат не змусить чекати!</p>
            </div>

            <div class="row justify-content-center">
                <div class="col-md-6 col-lg-5 col-xl-4 wow fadeInUp d-flex" data-wow-delay="0.3s">
                    <div class="shine-home-service-card shine-home-team-card team-item w-100 d-flex flex-column">
                        <div class="shine-home-service-media position-relative flex-shrink-0">
                            <img src="img/foto47.jpg" class="shine-home-service-img" alt="Леся Зелінська" loading="lazy" decoding="async">
                        </div>
                        <div class="shine-home-service-body text-center p-4 flex-grow-1 d-flex flex-column justify-content-center">
                            <h5 class="mb-2">Леся Зелінська</h5>
                            <p class="mb-0">Косметолог — фахівець, який збереже вашу молодість.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <!-- ==== Кінець Команди ==== -->

    <!-- ==== Партнери / Бренди ==== -->
    <section class="shine-home-partners position-relative">
        <div class="container py-5">
            <div class="section-title mb-5 text-center wow fadeInUp" data-wow-delay="0.2s">
                <div class="sub-style">
                    <h4 class="sub-title px-3 mb-0">З чим ми працюємо</h4>
                </div>
                <h3 class="display-6 mb-3">Ми використовуємо тільки преміум-косметику</h3>
                <p>У SHINE ми використовуємо тільки косметику преміум-класу — для найкращих результатів і безпеки шкіри.</p>
            </div>

            <div class="row g-4 justify-content-center align-items-stretch shine-home-partners-row">
                <div class="col-12 col-sm-10 col-md-6 col-lg-4 wow fadeInUp shine-home-partner-col d-flex" data-wow-delay="0.1s">
                    <div class="shine-home-partner-card shine-brand-card w-100">
                        <div class="shine-home-partner-card-inner">
                            <div class="shine-home-partner-logo-wrap">
                                <img src="/img/saypha-Logo-with-subtitles.jpg" class="shine-home-partner-logo" alt="Saypha" loading="lazy" decoding="async">
                            </div>
                            <div class="shine-home-partner-copy">
                                <span class="shine-home-partner-name">Saypha</span>
                                <span class="shine-home-partner-tagline">Преміальні препарати для контурної пластики та омолодження</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-sm-10 col-md-6 col-lg-4 wow fadeInUp shine-home-partner-col d-flex" data-wow-delay="0.2s">
                    <div class="shine-home-partner-card shine-brand-card w-100">
                        <div class="shine-home-partner-card-inner">
                            <div class="shine-home-partner-logo-wrap">
                                <img src="/img/glymed.jpeg" class="shine-home-partner-logo" alt="Glymed Plus" loading="lazy" decoding="async">
                            </div>
                            <div class="shine-home-partner-copy">
                                <span class="shine-home-partner-name">Glymed+</span>
                                <span class="shine-home-partner-tagline">Професійна медична косметика для догляду та відновлення шкіри</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-sm-10 col-md-6 col-lg-4 wow fadeInUp shine-home-partner-col d-flex" data-wow-delay="0.3s">
                    <div class="shine-home-partner-card shine-brand-card w-100">
                        <div class="shine-home-partner-card-inner">
                            <div class="shine-home-partner-logo-wrap">
                                <img src="/img/simild.png" class="shine-home-partner-logo" alt="Simildiet" loading="lazy" decoding="async">
                            </div>
                            <div class="shine-home-partner-copy">
                                <span class="shine-home-partner-name">Simildiet</span>
                                <span class="shine-home-partner-tagline">Лабораторна косметика преміум-сегменту з Іспанії</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="shine-home-partners-trust mt-5 pt-1 wow fadeInUp" data-wow-delay="0.35s">
                <ul class="shine-home-trust-list list-unstyled mb-0">
                    <li class="shine-home-trust-item">
                        <span class="shine-home-trust-icon" aria-hidden="true"><i class="bi bi-patch-check-fill"></i></span>
                        <span>Працюємо лише з <strong>сертифікованою</strong> косметикою</span>
                    </li>
                    <li class="shine-home-trust-item">
                        <span class="shine-home-trust-icon" aria-hidden="true"><i class="bi bi-award-fill"></i></span>
                        <span><strong>Офіційні партнери</strong> брендів — оригінальна продукція</span>
                    </li>
                    <li class="shine-home-trust-item">
                        <span class="shine-home-trust-icon" aria-hidden="true"><i class="bi bi-stars"></i></span>
                        <span><strong>Premium skincare</strong> для видимого результату й безпеки шкіри</span>
                    </li>
                </ul>
            </div>
        </div>
    </section>
    <!-- ==== Кінець Партнерів ==== -->
   
</div>

@code {
    private readonly List<ShineHero3DCarousel.HeroSlide> _heroSlides = new()
    {
        new("img/foto002.jpeg", "Фото студії краси SHINE"),
        new("img/saloncrasu2.jpg", "Інтер'єр салону"),
        new("img/foto35.jpeg", "Косметологічні процедури")
    };
}
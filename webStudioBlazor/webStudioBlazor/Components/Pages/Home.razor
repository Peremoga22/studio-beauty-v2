@page "/"


<!-- Головний контейнер -->
<div class="container-fluid p-0">

    <div class="px-2 px-md-3 pt-2">
        <ShineHero3DCarousel Slides="_heroSlides" />
    </div>

    <!-- ==== Послуги ==== -->
    <div class="container py-5">
        <div class="section-title mb-5 text-center wow fadeInUp" data-wow-delay="0.2s">
            <div class="sub-style">
                <h4 class="sub-title px-3 mb-0">Що ми робимо</h4>
            </div>
            <h1 class="display-5 mb-3">Наші послуги від експерта</h1>
            <p>Студія краси SHINE cosmetology by Lesia Zelinska пропонує комплексні послуги від кваліфікованого фахівця. Ваша краса — наш пріоритет.</p>
        </div>

        <div class="row g-4 justify-content-center">
            <!-- Косметологія -->
            <div class="col-md-6 col-lg-4 col-xl-3 wow fadeInUp" data-wow-delay="0.1s">
                <div class="service-item rounded shadow">
                    <img src="img/foto36.jpeg" class="img-fluid rounded-top w-100" alt="Косметологія" loading="lazy" decoding="async">
                    <div class="bg-light text-center p-4 rounded-bottom">
                        <h5 class="mb-3">Косметологія</h5>
                        <p>Чиста і оксамитова шкіра для сучасних дівчат - це запорука успіху, краси і впевненості в собі.</p>
                        <a href="/cosmetology"  class="btn-buy">Читати більше</a>
                    </div>
                </div>
            </div>

            <!-- Масажна терапія -->
            <div class="col-md-6 col-lg-4 col-xl-3 wow fadeInUp" data-wow-delay="0.2s">
                <div class="service-item rounded shadow">
                    <img src="img/foto45.jpeg" class="img-fluid rounded-top w-100" alt="Масаж" loading="lazy" decoding="async">
                    <div class="bg-light text-center p-4 rounded-bottom">
                        <h5 class="mb-3">Масажна терапія</h5>
                        <p>Відкрийте для себе світ релаксації та відновлення і здоров'я з нашою масажною терапією.</p>
                        <a href="/massage-therapy" class="btn-buy">Читати більше</a>
                    </div>
                </div>
            </div>
          
            <!-- Манікюр -->
          @*   <div class="col-md-6 col-lg-4 col-xl-3 wow fadeInUp" data-wow-delay="0.2s">
                <div class="service-item rounded shadow">
                    <div style="height: 380px; overflow: hidden;">
                        <img src="img/podologia.png"
                             class="img-fluid w-100 h-100 rounded-top"
                             style="object-fit: cover;"
                             alt="Масаж"
                             loading="lazy"
                             decoding="async">
                    </div>

                    <div class="bg-light text-center p-4 rounded-bottom">
                        <h5 class="mb-3">Подологія</h5>
                        <p>Подологія — це медична галузь, що займається діагностикою, лікуванням і профілактикою захворювань стопи, нігтів.</p>
                        <a href="/manicure" class="btn-buy">Читати більше</a>
                    </div>
                </div>
            </div> *@
        </div>
    </div>
    <!-- ==== Кінець Послуг ==== -->
    <!-- ==== Команда ==== -->
    <div class="container py-5">
        <div class="section-title mb-5 text-center wow fadeInUp" data-wow-delay="0.1s">
            <div class="sub-style">
                <h4 class="sub-title px-3 mb-0"> Наша команда</h4>
            </div>
            <h1 class="display-5 mb-3">Послуги професійної косметологині</h1>
            <p>Відчуйте турботу про себе з професіоналом SHINE. Результат не змусить чекати!</p>
        </div>

        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-4 wow fadeInUp" data-wow-delay="0.3s">
              <div class="team-item rounded shadow">                  
                    <img src="img/foto47.jpg" class="img-fluid rounded-top w-100" alt="Леся Зелінська" loading="lazy" decoding="async">
                    <div class="text-center bg-white border border-opacity-25 border-top-0 rounded-bottom p-4">

                        <h5 class="mb-1">Леся Зелінська</h5>
                        <p class="mb-0">Косметолог — фахівець, який збереже вашу молодість.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- ==== Кінець Команди ==== -->

    <!-- ==== Партнери / Бренди ==== -->
    <div class="container py-5">
        <div class="section-title mb-4 text-center wow fadeInUp" data-wow-delay="0.2s">
            <div class="sub-style">
                <h4 class="sub-title px-3 mb-0">З чим ми працюємо</h4>
            </div>
            <h3 class="display-6 mb-3">Ми використовуємо тільки преміум-косметику</h3>
            <p>У SHINE ми використовуємо тільки косметику преміум-класу — для найкращих результатів і безпеки шкіри.</p>
        </div>

        <div class="row justify-content-center">
            <div class="col-6 col-md-4 col-lg-3 mb-4 text-center">
                <img src="/img/saypha-Logo-with-subtitles.jpg" class="img-fluid w-75" alt="Saypha" loading="lazy" decoding="async">
            </div>
            <div class="col-6 col-md-4 col-lg-3 mb-4 text-center">
                <img src="/img/glymed.jpeg" class="img-fluid w-75" alt="Glymed" loading="lazy" decoding="async">
            </div>
            <div class="col-6 col-md-4 col-lg-3 mb-4 text-center">
                <img src="/img/simild.png" class="img-fluid w-75" alt="Simildiet" loading="lazy" decoding="async">
            </div>
        </div>
    </div>
    <!-- ==== Кінець Партнерів ==== -->
   
</div>

@code {
    private readonly List<ShineHero3DCarousel.HeroSlide> _heroSlides = new()
    {
        new("img/foto002.jpeg", "Фото студії краси SHINE"),
        new("img/saloncrasu2.jpg", "Інтер'єр салону"),
        new("img/foto35.jpeg", "Косметологічні процедури")
    };
}
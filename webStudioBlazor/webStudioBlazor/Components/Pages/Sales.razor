@page "/sales"
@implements IDisposable
@inject CartService _cartService
@inject SeedService _seedService
@inject NavigationManager _nav
@rendermode InteractiveServer

@if (_showAlert)
{
    <div class="@AlertCss" role="alert" style="z-index:1080;">
        <i class="bi bi-check-circle-fill me-1"></i>
        @_alertText
        <button type="button" class="btn-close ms-2" aria-label="Close" @onclick="HideAlert"></button>
    </div>
}

@{
    var page = pageTherapies.FirstOrDefault(p => p.TitlePage == selectedStore);
}

<section class="shine-sales-page py-2 pb-5">
    <div class="container">
        <header class="shine-sales-hero text-center mb-4">
            <h1 class="shine-sales-hero-title">@(page?.TitlePage ?? "Наш магазин")</h1>
            <p class="shine-sales-hero-text mx-auto mb-0">
                @(page?.DescriptionPage ?? "Преміальна косметика та догляд — оберіть продукти для вашої краси.")
            </p>
        </header>

        <nav class="shine-sales-breadcrumb mb-4" aria-label="Навігаційна стежка">
            <a href="/" class="shine-sales-breadcrumb-link">Домашня сторінка</a>
            <span class="shine-sales-breadcrumb-sep" aria-hidden="true">/</span>
            <span class="shine-sales-breadcrumb-current">Наш магазин</span>
        </nav>

        @if (page is null)
        {
            <p class="text-center text-muted py-5 mb-0">Завантаження каталогу…</p>
        }
        else
        {
            var cards = salesTherapyCards.Where(x => x.CategoryId == page.CategoryId).ToList();
            @if (!cards.Any())
            {
                <p class="text-center text-muted py-5 mb-0">Товари з’являться незабаром.</p>
            }
            else
            {
                <div class="row g-4 justify-content-center shine-sales-row">
                    @foreach (var item in cards)
                    {
                        <div class="col-12 col-sm-6 col-lg-4 d-flex">
                            <article class="shine-service-card shine-sales-product w-100 h-100 d-flex flex-column">
                                <img src="@item.ImagePath" class="shine-service-img flex-shrink-0" alt="@item.TitleCard" loading="lazy" decoding="async">
                                <div class="shine-sales-card-body p-4 d-flex flex-column flex-grow-1">
                                    <h2 class="shine-sales-card-title h5 mb-0">@item.TitleCard</h2>
                                    <p class="shine-sales-card-desc small text-muted mb-0">@item.DescriptionCard</p>
                                    <div class="shine-sales-price">
                                        <i class="bi bi-cash-stack me-1" aria-hidden="true"></i>
                                        @item.Price.ToString("C0", new System.Globalization.CultureInfo("uk-UA"))
                                    </div>
                                    <div class="shine-sales-card-footer d-grid gap-2">
                                        <button type="button" class="shine-hero-btn shine-sales-cart-btn w-100 border-0" @onclick="() => AddToCart(item.Id)">
                                            <i class="bi bi-bag-plus me-1" aria-hidden="true"></i>Додати в кошик
                                        </button>
                                        <a href="/appointment-user" class="shine-sales-btn-outline w-100 text-decoration-none text-center">Деталі / консультація</a>
                                    </div>
                                </div>
                            </article>
                        </div>
                    }
                </div>
            }
        }
    </div>
</section>

@code {
    private const string selectedStore = "Наш магазин";
    private List<PageTherapy> pageTherapies = new();
    private List<TherapyCard> salesTherapyCards = new();
    [Parameter] public int TherapyId { get; set; }
    [Parameter] public int Quantity { get; set; } = 1;
    private bool _showAlert;
    private bool _fadeOut;
    private string _alertText = "";
    private string _alertType = "success";
    private int cartCount;
    private string? currentUrl;

    protected override async Task OnInitializedAsync()
    {
        pageTherapies = await _seedService.GetAllPageTherapyListAsync();
        salesTherapyCards = await _seedService.GetAllTherapyCardListAsync();

        _cartService.CartCountChanged += count => { cartCount = count; InvokeAsync(StateHasChanged); };
        await _cartService.NotifyCountChangedAsync();
        currentUrl = _nav.ToBaseRelativePath(_nav.Uri);
        _nav.LocationChanged += OnLocationChanged;
    }

    private async Task AddToCart(int Id)
    {
        await _cartService.AddOrIncrementAsync(Id, Quantity);
        _cartService.IncreaseHeaderCount(Quantity);
        await ShowAlertAsync("Товар додано", "success");
        await InvokeAsync(StateHasChanged);
    }

    private string AlertCss =>
        $"alert alert-{_alertType} fade {(_fadeOut ? "" : "show")}" +
        " position-fixed top-0 end-0 m-3 shadow";

    private async Task ShowAlertAsync(string text, string type = "success")
    {
        _alertText = text;
        _alertType = type;
        _fadeOut = false;
        _showAlert = true;
        StateHasChanged();

        await Task.Delay(2700);
        _fadeOut = true;
        StateHasChanged();

        await Task.Delay(300);
        _showAlert = false;
        StateHasChanged();
    }

    private void HideAlert()
    {
        _showAlert = false;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = _nav.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        _nav.LocationChanged -= OnLocationChanged;
    }
}

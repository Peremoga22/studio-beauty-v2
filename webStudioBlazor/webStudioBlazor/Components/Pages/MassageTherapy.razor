@page "/massage-therapy"
@inject SeedService _seedService

@{
    var page = pageTherapies.FirstOrDefault(p => p.TitlePage == selectedMassage);
}

<section class="shine-massage-page">
    <div class="shine-massage-inner">
        <header class="shine-massage-hero" aria-labelledby="shine-massage-hero-heading">
            <div class="shine-massage-hero-glass shine-massage-hero-glass-left" aria-hidden="true"></div>
            <div class="shine-massage-hero-glass shine-massage-hero-glass-right" aria-hidden="true"></div>
            <div class="shine-massage-hero-glow" aria-hidden="true"></div>

            <div class="shine-massage-hero-content">
                <span class="shine-massage-hero-label">SHINE MASSAGE THERAPY</span>
                <h1 class="shine-massage-hero-title" id="shine-massage-hero-heading">@(page?.TitlePage ?? "Масаж")</h1>
                <p class="shine-massage-hero-text">
                    @(page?.DescriptionPage ?? "Відновлення, розслаблення та турбота про тіло в атмосфері комфорту. Оберіть свій ритуал відпочинку разом з нами.")
                </p>
            </div>
        </header>

        <nav class="shine-massage-breadcrumb" aria-label="Навігаційна стежка">
            <a href="/" class="shine-massage-breadcrumb-link">Домашня сторінка</a>
            <span class="shine-massage-breadcrumb-sep" aria-hidden="true">/</span>
            <span class="shine-massage-breadcrumb-current">Масажна терапія</span>
        </nav>

        @if (page is null)
        {
            <p class="shine-massage-empty text-center text-muted py-5 mb-0">Завантаження розділу…</p>
        }
        else
        {
            var cards = massageTherapyCards.Where(x => x.CategoryId == page.CategoryId).ToList();
            @if (!cards.Any())
            {
                <p class="shine-massage-empty text-center text-muted py-5 mb-0">Послуги з’являться незабаром.</p>
            }
            else
            {
                <div class="shine-massage-services-grid">
                    @foreach (var item in cards)
                    {
                        <article class="shine-massage-service-card">
                            <div class="shine-massage-service-media">
                                <div class="ratio ratio-16x9 bg-dark">
                                    <lite-youtube class="object-fit-cover" videoid="@item.ImagePath" title="@item.TitleCard"></lite-youtube>
                                </div>
                            </div>
                            <div class="shine-massage-service-body">
                                <h2 class="shine-massage-service-title">@item.TitleCard</h2>
                                <p class="shine-massage-service-desc">@item.DescriptionCard</p>
                                <div class="shine-massage-service-meta">
                                    <span><i class="bi bi-clock me-1" aria-hidden="true"></i>Тривалість: за домовленістю</span>
                                    <span><i class="bi bi-cash-stack me-1" aria-hidden="true"></i>@item.Price.ToString("C0", new System.Globalization.CultureInfo("uk-UA"))</span>
                                </div>
                                <div class="shine-massage-service-footer">
                                    <a href="/appointment-user" class="shine-massage-service-btn text-decoration-none">Записатися</a>
                                </div>
                            </div>
                        </article>
                    }
                </div>
            }
        }
    </div>
</section>

@code {
    private List<TherapyCard> massageTherapyCards = new();
    private List<PageTherapy> pageTherapies = new();
    private const string selectedMassage = "Масаж";

    protected override async Task OnInitializedAsync()
    {
        massageTherapyCards = await _seedService.GetAllTherapyCardListAsync();
        pageTherapies = await _seedService.GetAllPageTherapyListAsync();
    }
}

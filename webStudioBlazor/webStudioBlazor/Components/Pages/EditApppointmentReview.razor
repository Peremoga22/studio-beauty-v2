@page "/add-appointment-review/{CurrentUserId}"
@using System.ComponentModel.DataAnnotations
@inject SeedService _seedService
@inject NavigationManager _nav
@rendermode InteractiveServer
@attribute [Authorize]

<section class="shine-history-page">
    <div class="shine-history-inner">
        <header class="shine-history-header text-center">
            <span class="shine-history-kicker">Відгуки</span>
            <h1 class="shine-history-title">Новий відгук</h1>
            <p class="shine-history-lead mb-0">
                Опишіть враження від візиту — нам важливо знати, що вдалося, а що можна покращити.
            </p>
        </header>

        <nav class="shine-history-breadcrumb shine-history-breadcrumb--wrap mb-4" aria-label="Навігаційна стежка">
            <a href="/account/profile" class="shine-history-breadcrumb-link">Особистий кабінет</a>
            <span class="shine-history-breadcrumb-sep" aria-hidden="true">/</span>
            <a href="@($"/appointment-reviews/{CurrentUserId}")" class="shine-history-breadcrumb-link">Мої відгуки</a>
            <span class="shine-history-breadcrumb-sep" aria-hidden="true">/</span>
            <span class="shine-history-breadcrumb-current">Додати відгук</span>
        </nav>

        <div class="shine-review-form-wrap mx-auto">
            <div class="shine-review-form-card">
                <h2 class="shine-review-form-section-title mb-4">Відгук про послугу</h2>

                <EditForm Model="@reviewModel"
                          OnValidSubmit="HandleValidSubmitReview"
                          class="shine-review-form">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="shine-review-validation-summary mb-4" />

                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold small shine-review-label">Категорія *</label>
                            <InputSelect class="form-select"
                                         @bind-Value="reviewModel.CategoryId"
                                         TValue="int">
                                <option value="0">Оберіть категорію</option>
                                @foreach (var cat in categories)
                                {
                                    <option value="@cat.Id">@cat.NameCategory</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => reviewModel.CategoryId)"
                                               class="text-danger small" />
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-semibold small shine-review-label">Послуга *</label>
                            <InputSelect class="form-select"
                                         @bind-Value="reviewModel.TherapyId"
                                         TValue="int">
                                <option value="0">Оберіть послугу</option>
                                @foreach (var srv in therapyCards.Where(e => e.CategoryId == reviewModel.CategoryId))
                                {
                                    <option value="@srv.Id">@srv.TitleCard</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => reviewModel.TherapyId)"
                                               class="text-danger small" />
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-semibold small shine-review-label">Майстер *</label>
                            <InputSelect class="form-select"
                                         @bind-Value="reviewModel.MasterId"
                                         TValue="int">
                                <option value="0">Оберіть майстра</option>
                                @foreach (var master in masters)
                                {
                                    <option value="@master.Id">@master.FullName</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => reviewModel.MasterId)"
                                               class="text-danger small" />
                        </div>

                        @if (AppUserId != 0)
                        {
                            <div class="col-12">
                                <p class="shine-review-appointment-meta mb-0 small">
                                    <strong>Дата запису:</strong>
                                    @clientUser.AppointmentDate.ToString("dd.MM.yyyy")
                                    о @clientUser.SetHour
                                </p>
                            </div>
                        }

                        <div class="col-12 col-md-6">
                            <label class="form-label fw-semibold small shine-review-label">Оцінка *</label>
                            <InputSelect @bind-Value="reviewModel.Rating"
                                         class="form-select"
                                         TValue="int">
                                <option value="0">Оберіть оцінку</option>
                                @for (var i = 1; i <= 5; i++)
                                {
                                    <option value="@i">@i з 5</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => reviewModel.Rating)"
                                               class="text-danger small" />
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-semibold small shine-review-label">Ваш відгук *</label>
                            <InputTextArea @bind-Value="reviewModel.Comment"
                                           class="form-control"
                                           rows="4"
                                           placeholder="Поділіться своїми враженнями…" />
                            <ValidationMessage For="@(() => reviewModel.Comment)"
                                               class="text-danger small" />
                        </div>
                    </div>

                    @if (AppUserId == 0)
                    {
                        <div class="shine-review-notice mt-4" role="status">
                            <p class="shine-review-notice-text mb-0">
                                Щоб залишати відгуки, скористайтеся послугами студії або зробіть покупку в нашому магазині.
                            </p>
                        </div>
                    }
                    else
                    {
                        <div class="text-center mt-4">
                            <button type="submit" class="shine-review-submit">
                                Додати відгук
                            </button>
                        </div>
                    }
                </EditForm>
            </div>
        </div>
    </div>
</section>

@code {
    [Parameter]
    public string CurrentUserId { get; set; } = string.Empty;

    private Appointment clientUser = new();
    private ReviewInput reviewModel = new();

    private List<Appointment> clientList = new();
    private List<Master> masters = new();
    private List<Category> categories = new();
    private List<TherapyCard> therapyCards = new();

    private int AppUserId;

    protected override async Task OnInitializedAsync()
    {
        masters = await _seedService.GetAllMasterListAsync();
        categories = await _seedService.GetAllCategoryListAsync();
        therapyCards = await _seedService.GetAllTherapyCardListAsync();
        clientList = await _seedService.GetAllClientListAsync();
        AppUserId = clientList.FirstOrDefault(a => a.UserId == CurrentUserId)?.Id ?? 0;
        clientUser = await _seedService.GetClientAppointmentId(AppUserId) ?? new Appointment();
    }

    private async Task HandleValidSubmitReview()
    {
        if (string.IsNullOrEmpty(CurrentUserId))
        {
            return;
        }

        if (AppUserId == 0)
        {
            return;
        }

        var review = new Review
        {
            Rating = reviewModel.Rating,
            Comment = reviewModel.Comment,
            AppointmentId = AppUserId,
            CategoryId = reviewModel.CategoryId,
            TherapyId = reviewModel.TherapyId,
            MasterId = reviewModel.MasterId,
            UserId = CurrentUserId,
            CreatedAt = DateTime.UtcNow
        };

        await _seedService.AddReviewAsync(review);

        _nav.NavigateTo($"/appointment-reviews/{CurrentUserId}");
    }

    public class ReviewInput
    {
        public int Id { get; set; }

        [Required(ErrorMessage = "Категорія не вибрана")]
        [Range(1, int.MaxValue, ErrorMessage = "Будь ласка, оберіть категорію")]
        public int CategoryId { get; set; }

        [Required(ErrorMessage = "Послуга не вибрана")]
        [Range(1, int.MaxValue, ErrorMessage = "Будь ласка, оберіть послугу")]
        public int TherapyId { get; set; }

        [Required(ErrorMessage = "Майстер не вибраний")]
        [Range(1, int.MaxValue, ErrorMessage = "Будь ласка, оберіть майстра")]
        public int MasterId { get; set; }

        [Range(1, 5, ErrorMessage = "Оцінка має бути від 1 до 5")]
        public int Rating { get; set; }

        [Required(ErrorMessage = "Введіть текст відгуку")]
        [StringLength(1000)]
        public string Comment { get; set; } = string.Empty;
    }
}

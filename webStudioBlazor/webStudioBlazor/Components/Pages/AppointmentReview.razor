@page "/appointment-reviews/{AppointmentId}"
@using webStudioBlazor.Data
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@inject SeedService _seedService
@inject NavigationManager NavigationManager
@attribute [Authorize]

<section class="shine-history-page">
    <div class="shine-history-inner">
        <header class="shine-history-header text-center">
            <span class="shine-history-kicker">Відгуки</span>
            <h1 class="shine-history-title">Мої відгуки</h1>
            <p class="shine-history-lead mb-0">
                Поділіться враженнями після візиту — це допомагає нам ставати кращими.
            </p>
        </header>

        <nav class="shine-history-breadcrumb mb-4" aria-label="Навігаційна стежка">
            <a href="/account/profile" class="shine-history-breadcrumb-link">Особистий кабінет</a>
            <span class="shine-history-breadcrumb-sep" aria-hidden="true">/</span>
            <span class="shine-history-breadcrumb-current">Мої відгуки</span>
        </nav>

        @if (isLoading)
        {
            <div class="shine-history-loading text-center py-5">
                <div class="spinner-border shine-history-spinner" role="status" aria-label="Завантаження">
                    <span class="visually-hidden">Завантаження…</span>
                </div>
            </div>
        }
        else if (!reviews.Any())
        {
            <div class="shine-history-empty text-center mb-4">
                <div class="shine-history-empty-card">
                    <i class="fa-solid fa-comment-dots shine-history-empty-icon" aria-hidden="true"></i>
                    <p class="shine-history-empty-title mb-2">Ви ще не залишали відгуків</p>
                    <p class="shine-history-empty-text mb-0">
                        Розкажіть про свій досвід — нам важливо почути вас.
                    </p>
                    <a href="@($"/add-appointment-review/{AppointmentId}")"
                       class="shine-history-empty-cta text-decoration-none mt-4 d-inline-flex align-items-center justify-content-center">
                        Залишити відгук
                    </a>
                </div>
            </div>
        }
        else
        {
            <div class="shine-history-review-banner d-flex flex-column flex-md-row align-items-stretch align-items-md-center justify-content-between gap-3 mb-4">
                <span class="shine-history-review-banner-text">Хочете додати ще один відгук?</span>
                <a href="@($"/add-appointment-review/{AppointmentId}")"
                   class="shine-history-review-banner-btn text-decoration-none text-center">
                    <i class="fa-solid fa-face-smile-beam me-2" aria-hidden="true"></i>Залишити відгук
                </a>
            </div>

            <div class="row g-4">
                @foreach (var r in reviews)
                {
                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="card border-0 h-100 shine-history-review-card">
                            <div class="card-body p-4 d-flex flex-column">
                                <p class="shine-history-review-client text-center mb-3 mb-md-0">
                                    @r.Appointment.ClientName
                                </p>
                                <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                                    <h2 class="h6 fw-bold mb-0 shine-history-review-service">
                                        @r.TherapyCard?.TitleCard
                                    </h2>
                                    <time class="shine-history-review-date flex-shrink-0" datetime="@r.CreatedAt.ToString("yyyy-MM-dd")">
                                        @r.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")
                                    </time>
                                </div>
                                <div class="shine-history-stars mb-3" aria-label="Оцінка @r.Rating з 5">
                                    @for (var i = 1; i <= 5; i++)
                                    {
                                        if (i <= r.Rating)
                                        {
                                            <i class="fa-solid fa-star shine-history-star-on" aria-hidden="true"></i>
                                        }
                                        else
                                        {
                                            <i class="fa-regular fa-star shine-history-star-off" aria-hidden="true"></i>
                                        }
                                    }
                                </div>
                                <p class="shine-history-review-comment small flex-grow-1 mb-3">
                                    @r.Comment
                                </p>
                                <div class="shine-history-review-master small mt-auto">
                                    <span class="text-muted">Майстер:</span>
                                    <strong class="ms-1">@r.Master?.FullName</strong>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>

@code {
    [Parameter] public string AppointmentId { get; set; } = string.Empty;

    private List<Review> reviews = new();
    private bool isLoading = true;

    [CascadingParameter]
    private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        _ = await AuthStateTask;

        if (!string.IsNullOrEmpty(AppointmentId))
        {
            reviews = await _seedService.GetReviewsForUserAsync(AppointmentId);
        }

        isLoading = false;
    }
}

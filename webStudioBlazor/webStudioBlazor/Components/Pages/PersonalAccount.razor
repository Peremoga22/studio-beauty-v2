@page "/account/profile"
@page "/personal-account"

@attribute [Authorize]
@rendermode InteractiveServer

@using System.ComponentModel.DataAnnotations
@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using webStudioBlazor.Data

@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthenticationStateProvider

<section class="shine-account-page">
    <div class="shine-account-inner">
        <header class="shine-account-hero" aria-labelledby="shine-account-hero-heading">
            <div class="shine-account-hero-glass shine-account-hero-glass-left" aria-hidden="true"></div>
            <div class="shine-account-hero-glass shine-account-hero-glass-right" aria-hidden="true"></div>
            <div class="shine-account-hero-glow" aria-hidden="true"></div>

            <div class="shine-account-hero-content">
                <span class="shine-account-hero-label">SHINE COSMETOLOGY</span>
                <h1 class="shine-account-hero-title" id="shine-account-hero-heading">Особистий кабінет</h1>
                <p class="shine-account-hero-text">
                    Переглядайте записи, замовлення та акції в одному місці — зручно й без зайвих кроків.
                </p>
            </div>
        </header>

        <nav class="shine-account-breadcrumb mb-4" aria-label="Навігаційна стежка">
            <a href="/" class="shine-account-breadcrumb-link">Домашня сторінка</a>
            <span class="shine-account-breadcrumb-sep" aria-hidden="true">/</span>
            <span class="shine-account-breadcrumb-current">Особистий кабінет</span>
        </nav>

        @if (profileUser is not null && !IsProfileIncomplete && !string.IsNullOrWhiteSpace(profileSaveMessage))
        {
            <div class="alert alert-success py-2 mb-4" role="status">@profileSaveMessage</div>
        }

        @if (profileUser is not null && IsProfileIncomplete)
        {
            <div class="profile-alert mb-4" role="region" aria-labelledby="profile-complete-heading">
                <h4 class="h5 mb-2" id="profile-complete-heading">Доповніть ваш профіль</h4>
                <p class="mb-4">
                    Щоб ми могли коректно оформлювати записи, додайте ім’я, прізвище та номер телефону.
                </p>

                @if (profileIdentityErrors is { Count: > 0 })
                {
                    <div class="alert alert-danger py-2 mb-3" role="alert">
                        @string.Join(" ", profileIdentityErrors.Select(e => e.Description))
                    </div>
                }

                <EditForm Model="profileInput" OnValidSubmit="SaveProfileAsync" FormName="complete-profile">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="text-danger mb-3" />

                    <div class="form-floating mb-3">
                        <InputText id="pa-first" class="form-control" @bind-Value="profileInput.FirstName" placeholder="Ім’я" autocomplete="given-name" />
                        <label for="pa-first">Ім’я</label>
                        <ValidationMessage For="() => profileInput.FirstName" class="text-danger small d-block" />
                    </div>
                    <div class="form-floating mb-3">
                        <InputText id="pa-last" class="form-control" @bind-Value="profileInput.LastName" placeholder="Прізвище" autocomplete="family-name" />
                        <label for="pa-last">Прізвище</label>
                        <ValidationMessage For="() => profileInput.LastName" class="text-danger small d-block" />
                    </div>
                    <div class="form-floating mb-4">
                        <InputText id="pa-phone" class="form-control" @bind-Value="profileInput.PhoneNumber" placeholder="+380671234567" autocomplete="tel" />
                        <label for="pa-phone">Номер телефону</label>
                        <ValidationMessage For="() => profileInput.PhoneNumber" class="text-danger small d-block" />
                    </div>

                    <button class="btn-save" type="submit">Зберегти дані</button>
                </EditForm>
            </div>
        }

        @if (profileUser is not null && !IsProfileIncomplete)
        {
            <section class="shine-account-profile-card" aria-labelledby="profile-heading">
                <h2 class="h5 mb-3 shine-login-card-title" id="profile-heading">Ваші дані</h2>
                <dl class="shine-account-profile-dl row mb-0">
                    <div class="col-md-6">
                        <dt>Ім'я</dt>
                        <dd>@(string.IsNullOrWhiteSpace(profileUser.FirstName) ? "—" : profileUser.FirstName)</dd>
                    </div>
                    <div class="col-md-6">
                        <dt>Прізвище</dt>
                        <dd>@(string.IsNullOrWhiteSpace(profileUser.LastName) ? "—" : profileUser.LastName)</dd>
                    </div>
                    <div class="col-md-6">
                        <dt>Телефон</dt>
                        <dd>@(string.IsNullOrWhiteSpace(profileUser.PhoneNumber) ? "—" : profileUser.PhoneNumber)</dd>
                    </div>
                    <div class="col-md-6">
                        <dt>Email</dt>
                        <dd>@(string.IsNullOrWhiteSpace(profileUser.Email) ? "—" : profileUser.Email)</dd>
                    </div>
                </dl>
                <p class="small text-muted mb-0">
                    Історія записів та відгуки — у блоках нижче; залишити відгук можна після візиту до студії.
                </p>
            </section>
        }

        <section class="shine-account-grid-section py-2 pb-5">
            <div class="container">
                <div class="row g-3 g-md-4 justify-content-center shine-account-row">
                    <!-- Косметологія -->
                    <div class="col-12 col-sm-6 col-lg-4 d-flex">
                        <div class="shine-account-card w-100 d-flex flex-column text-center">
                            <div class="shine-account-card-top">
                                <i class="fa-solid fa-face-smile-beam fa-2x mb-3 shine-account-icon" aria-hidden="true"></i>
                                <h2 class="h5 mb-2">Косметологія — мої записи</h2>
                                <p class="shine-account-card-text mb-0">
                                    Догляд за шкірою: чищення, пілінги, anti-age та інші процедури.
                                </p>
                            </div>
                            <a href="@($"/history-of-cosmetology-services/{UserId}")"
                               class="shine-hero-btn shine-account-cta text-decoration-none mt-auto align-self-stretch text-center justify-content-center">
                                <i class="fa-solid fa-face-smile-beam fa-1x me-1" aria-hidden="true"></i>Перейти →
                            </a>
                        </div>
                    </div>

                    <!-- Масажна терапія -->
                    <div class="col-12 col-sm-6 col-lg-4 d-flex">
                        <div class="shine-account-card w-100 d-flex flex-column text-center">
                            <div class="shine-account-card-top">
                                <i class="fa-solid fa-spa fa-2x mb-3 shine-account-icon" aria-hidden="true"></i>
                                <h2 class="h5 mb-2">Масажна терапія — мої записи</h2>
                                <p class="shine-account-card-text mb-0">
                                    Релакс, відновлення тіла та зняття м’язової напруги.
                                </p>
                            </div>
                            <a href="@($"/history-of-massage-services/{UserId}")"
                               class="shine-hero-btn shine-account-cta text-decoration-none mt-auto align-self-stretch text-center justify-content-center">
                                <i class="fa-solid fa-spa fa-1x me-1" aria-hidden="true"></i>Перейти →
                            </a>
                        </div>
                    </div>

                    <!-- Манікюр -->
                   @*  <div class="col-12 col-sm-6 col-lg-4 d-flex">
                        <div class="shine-account-card w-100 d-flex flex-column text-center">
                            <div class="shine-account-card-top">
                                <i class="fa-solid fa-hand-sparkles fa-2x mb-3 shine-account-icon" aria-hidden="true"></i>
                                <h2 class="h5 mb-2">Манікюр — мої записи</h2>
                                <p class="shine-account-card-text mb-0">
                                    Ідеальний манікюр, що підкреслює вашу індивідуальність та додає впевненості.
                                </p>
                            </div>
                            <a href="@($"/history-of-manicure-services/{UserId}")"
                               class="shine-hero-btn shine-account-cta text-decoration-none mt-auto align-self-stretch text-center justify-content-center">
                                <i class="fa-solid fa-hand-sparkles fa-1x me-1" aria-hidden="true"></i>Перейти →
                            </a>
                        </div>
                    </div> *@

                    <!-- Мої покупки -->
                    <div class="col-12 col-sm-6 col-lg-4 d-flex">
                        <div class="shine-account-card w-100 d-flex flex-column text-center">
                            <div class="shine-account-card-top">
                                <i class="bi bi-bag-heart-fill fs-2 mb-3 shine-account-icon d-block" aria-hidden="true"></i>
                                <h2 class="h5 mb-2">Мої покупки</h2>
                                <p class="shine-account-card-text mb-0">Професійна косметика та товари для догляду.</p>
                            </div>
                            <a href="@($"/history-of-sales-services/{UserId}")"
                               class="shine-hero-btn shine-account-cta text-decoration-none mt-auto align-self-stretch text-center justify-content-center">
                                <i class="bi bi-bag-heart-fill me-1" aria-hidden="true"></i>Перейти →
                            </a>
                        </div>
                    </div>

                    <!-- Відгуки -->
                    <div class="col-12 col-sm-6 col-lg-4 d-flex">
                        <div class="shine-account-card w-100 d-flex flex-column text-center">
                            <div class="shine-account-card-top">
                                <i class="fa-solid fa-comment-dots fa-2x mb-3 shine-account-icon" aria-hidden="true"></i>
                                <h2 class="h5 mb-2">Створити відгуки</h2>
                                <p class="shine-account-card-text mb-0">Поділіться враженнями про наші послуги.</p>
                            </div>
                            <a href="@($"/appointment-reviews/{UserId}")"
                               class="shine-hero-btn shine-account-cta text-decoration-none mt-auto align-self-stretch text-center justify-content-center">
                                <i class="fa-solid fa-comment-dots fa-1x me-1" aria-hidden="true"></i>Перейти →
                            </a>
                        </div>
                    </div>

                    <!-- Подарункові сертифікати -->
                    <div class="col-12 col-sm-6 col-lg-4 d-flex">
                        <div class="shine-account-card w-100 d-flex flex-column text-center">
                            <div class="shine-account-card-top">
                                <i class="fa-solid fa-gift fa-2x mb-3 shine-account-icon" aria-hidden="true"></i>
                                <h2 class="h5 mb-2">Подарункові сертифікати</h2>
                                <p class="shine-account-card-text mb-0">Подаруйте близьким красу, турботу та емоції.</p>
                            </div>
                            <a href="@($"/history-of-gift-sertificate-services/{UserId}")"
                               class="shine-hero-btn shine-account-cta text-decoration-none mt-auto align-self-stretch text-center justify-content-center">
                                <i class="fa-solid fa-gift fa-1x me-1" aria-hidden="true"></i>Перейти →
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </div>
</section>

@code {
    private string UserId { get; set; } = string.Empty;
    private ApplicationUser? profileUser;
    private ClaimsPrincipal authPrincipal = default!;
    private readonly ProfileInput profileInput = new();
    private string? profileSaveMessage;
    private List<IdentityError>? profileIdentityErrors;

    private bool IsProfileIncomplete =>
        profileUser is not null && (
            string.IsNullOrWhiteSpace(profileUser.FirstName) ||
            string.IsNullOrWhiteSpace(profileUser.LastName) ||
            string.IsNullOrWhiteSpace(profileUser.PhoneNumber));

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        authPrincipal = authState.User;

        UserId =
            authPrincipal.FindFirst(ClaimTypes.NameIdentifier)?.Value ??
            authPrincipal.FindFirst(ClaimTypes.Email)?.Value ??
            authPrincipal.FindFirst("email")?.Value ??
            authPrincipal.Identity?.Name ??
            string.Empty;

        if (authPrincipal.Identity?.IsAuthenticated == true)
        {
            profileUser = await UserManager.GetUserAsync(authPrincipal);
            MapProfileToInput();
        }
    }

    private void MapProfileToInput()
    {
        if (profileUser is null) return;
        profileInput.FirstName = profileUser.FirstName ?? "";
        profileInput.LastName = profileUser.LastName ?? "";
        profileInput.PhoneNumber = profileUser.PhoneNumber ?? "";
    }

    private async Task SaveProfileAsync()
    {
        profileSaveMessage = null;
        profileIdentityErrors = null;

        if (profileUser is null) return;

        profileUser.FirstName = profileInput.FirstName.Trim();
        profileUser.LastName = profileInput.LastName.Trim();
        profileUser.PhoneNumber = profileInput.PhoneNumber.Trim();

        var result = await UserManager.UpdateAsync(profileUser);
        if (!result.Succeeded)
        {
            profileIdentityErrors = result.Errors.ToList();
            return;
        }

        profileUser = await UserManager.GetUserAsync(authPrincipal);
        MapProfileToInput();
        profileSaveMessage = "Дані збережено.";
    }

    private sealed class ProfileInput
    {
        [Required(ErrorMessage = "Введіть ім’я.")]
        [StringLength(100, MinimumLength = 2, ErrorMessage = "Ім’я — від 2 до 100 символів.")]
        public string FirstName { get; set; } = "";

        [Required(ErrorMessage = "Введіть прізвище.")]
        [StringLength(100, MinimumLength = 2, ErrorMessage = "Прізвище — від 2 до 100 символів.")]
        public string LastName { get; set; } = "";

        [Required(ErrorMessage = "Введіть номер телефону.")]
        [RegularExpression(@"^(\+380|0)\d{9}$", ErrorMessage = "Формат: +380XXXXXXXXX або 0XXXXXXXXX.")]
        public string PhoneNumber { get; set; } = "";
    }
}

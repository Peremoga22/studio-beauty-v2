@page "/cosmetology"
@inject SeedService _seedService

@{
    var page = pageTherapies.FirstOrDefault(p => p.TitlePage == selectedCosmetology);
}

<section class="shine-cosmo-page">
    <div class="shine-cosmo-page-inner">
        <header class="shine-cosmo-hero">
            <span class="shine-cosmo-hero-label">SHINE COSMETOLOGY</span>
            <h1 class="shine-cosmo-hero-title">@(page?.TitlePage ?? "Косметологія")</h1>
            <p class="shine-cosmo-hero-text">
                @(page?.DescriptionPage ?? "Професійний догляд за шкірою, сучасні методики та індивідуальний підхід для вашої краси, молодості й впевненості.")
            </p>
        </header>

        <nav class="shine-cosmo-breadcrumb" aria-label="Навігаційна стежка">
            <a href="/" class="shine-cosmo-breadcrumb-link">Домашня сторінка</a>
            <span class="shine-cosmo-breadcrumb-sep" aria-hidden="true">/</span>
            <span class="shine-cosmo-breadcrumb-current">Косметологія</span>
        </nav>

        @if (page is null)
        {
            <p class="shine-cosmo-empty text-center text-muted py-5 mb-0">Завантаження розділу…</p>
        }
        else
        {
            var cards = cosmetologyTherapyCards.Where(x => x.CategoryId == page.CategoryId).ToList();
            @if (!cards.Any())
            {
                <p class="shine-cosmo-empty text-center text-muted py-5 mb-0">Послуги з’являться незабаром.</p>
            }
            else
            {
                <div class="shine-cosmo-services-grid">
                    @foreach (var item in cards)
                    {
                        <article class="shine-cosmo-service-card">
                            <div class="shine-cosmo-service-image">
                                <img src="@item.ImagePath" alt="@item.TitleCard" loading="lazy" decoding="async" />
                            </div>
                            <div class="shine-cosmo-service-body">
                                <h2 class="shine-cosmo-service-title">@item.TitleCard</h2>
                                <p class="shine-cosmo-service-desc">@item.DescriptionCard</p>
                                <div class="shine-cosmo-service-footer">
                                    <span class="shine-cosmo-service-time">@item.Price.ToString("C0", new System.Globalization.CultureInfo("uk-UA"))</span>
                                    <a href="/appointment-user" class="shine-cosmo-service-btn text-decoration-none">Записатися</a>
                                </div>
                            </div>
                        </article>
                    }
                </div>
            }
        }
    </div>
</section>

@code {
    private List<TherapyCard> cosmetologyTherapyCards = new();
    private List<PageTherapy> pageTherapies = new();
    private const string selectedCosmetology = "Косметологія";

    protected override async Task OnInitializedAsync()
    {
        cosmetologyTherapyCards = await _seedService.GetAllTherapyCardListAsync();
        pageTherapies = await _seedService.GetAllPageTherapyListAsync();
    }
}

@page "/our-reviews-for-stududia"
@using webStudioBlazor.Data
@inject SeedService _seedService

<div class="shine-reviews-page py-4 py-md-5">
    <section class="shine-reviews-hero px-3 px-md-4" aria-labelledby="shine-reviews-hero-heading">
        <div class="shine-reviews-hero-card-3d shine-reviews-hero-card-left" aria-hidden="true"></div>
        <div class="shine-reviews-hero-card-3d shine-reviews-hero-card-right" aria-hidden="true"></div>

        <div class="shine-reviews-hero-content">
            <div class="shine-reviews-hero-label">SHINE COSMETOLOGY</div>
            <h1 class="shine-reviews-hero-title" id="shine-reviews-hero-heading">Відгуки клієнтів</h1>
            <p class="shine-reviews-hero-text">
                Щирі враження після процедур, турботливого сервісу та професійного догляду.
                Для нас важлива ваша довіра, комфорт і результат.
            </p>
            <a href="/appointment-user" class="shine-reviews-hero-btn text-decoration-none">Записатися</a>
        </div>
    </section>

    <div class="container">
        @if (_loading)
        {
            <p class="shine-reviews-loading text-center text-muted mb-0">Завантаження…</p>
        }
        else if (!reviews.Any())
        {
            <div class="shine-reviews-empty shine-reviews-panel text-center">
                <i class="bi bi-chat-heart shine-reviews-empty-icon" aria-hidden="true"></i>
                <p class="mb-2 fw-semibold">Поки немає відгуків</p>
                <p class="small text-muted mb-0">
                    Після візиту ви зможете залишити відгук у своєму акаунті.
                </p>
            </div>
        }
        else
        {
            <div class="shine-reviews-notice shine-reviews-panel d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-3 mb-4">
                <span class="shine-reviews-notice-text mb-0">
                    Щоб залишити свій відгук, зареєструйтеся, увійдіть у систему та перейдіть до особистого кабінету.
                </span>
                <i class="bi bi-shield-lock shine-reviews-notice-icon flex-shrink-0" aria-hidden="true"></i>
            </div>

            <div class="row g-4">
                @foreach (var r in reviews)
                {
                    <div class="col-12 col-md-6 col-lg-4">
                        <article class="shine-review-card shine-reviews-card p-4 h-100 d-flex flex-column">
                            <p class="shine-reviews-client text-center fw-semibold mb-3">
                                @r.Appointment.ClientName
                            </p>
                            <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                                <h3 class="shine-reviews-service h6 mb-0">
                                    @r.TherapyCard?.TitleCard
                                </h3>
                                <time class="shine-reviews-date small flex-shrink-0" datetime="@r.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")">
                                    @r.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")
                                </time>
                            </div>
                            <div class="shine-reviews-stars mb-3" aria-label="Оцінка @r.Rating з 5">
                                @for (var i = 1; i <= 5; i++)
                                {
                                    if (i <= r.Rating)
                                    {
                                        <i class="fa-solid fa-star shine-reviews-star shine-reviews-star-on" aria-hidden="true"></i>
                                    }
                                    else
                                    {
                                        <i class="fa-regular fa-star shine-reviews-star" aria-hidden="true"></i>
                                    }
                                }
                            </div>
                            <p class="shine-reviews-comment small flex-grow-1 mb-3">
                                @r.Comment
                            </p>
                            <div class="shine-reviews-master small mt-auto pt-3">
                                <span class="text-muted">Майстер:</span>
                                <strong class="shine-reviews-master-name">@r.Master?.FullName</strong>
                            </div>
                        </article>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    private bool _loading = true;
    private List<Review> reviews = new();

    protected override async Task OnInitializedAsync()
    {
        reviews = await _seedService.GetAllReviewsForUserAsync();
        _loading = false;
    }
}

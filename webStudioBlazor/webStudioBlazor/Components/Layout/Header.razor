@implements IDisposable
@inject CartService _cartService
@rendermode InteractiveServer

<header class="shine-header w-100 min-w-0">
    <div class="shine-topbar shine-topbar-mobile d-lg-none">
        <div class="shine-topbar-mobile-bleed py-1 py-sm-2">
            <div class="shine-topbar-mobile-inner d-flex align-items-center justify-content-between gap-2">
                <a href="tel:+380669052664" class="shine-topbar-mobile-call text-decoration-none d-inline-flex align-items-center gap-2 min-w-0" title="Зателефонувати +380 66 905 26 64">
                    <i class="fas fa-phone-alt shine-topbar-mobile-call-icon flex-shrink-0"></i>
                    <span class="shine-topbar-mobile-call-text fw-semibold">+380&nbsp;66&nbsp;905&nbsp;26&nbsp;64</span>
                </a>
                <div class="shine-topbar-mobile-icons d-flex align-items-center flex-shrink-0 gap-1">
                    <a href="https://maps.app.goo.gl/S5UGHhxQ6fssKRFM7" class="shine-topbar-mobile-icon text-decoration-none" aria-label="Адреса на карті" title="Карта — Івано-Франківськ">
                        <i class="fas fa-map-marker-alt"></i>
                    </a>
                    <a href="mailto:shine.cosmetologybyzelinska@gmail.com" class="shine-topbar-mobile-icon text-decoration-none" aria-label="Написати листа" title="Написати на email">
                        <i class="fas fa-envelope"></i>
                    </a>
                    <a href="https://facebook.com" target="_blank" rel="noopener noreferrer" class="shine-topbar-mobile-icon text-decoration-none" aria-label="Facebook" title="Facebook">
                        <i class="fab fa-facebook-f"></i>
                    </a>
                    <a href="https://instagram.com/shinee.cosmetology" target="_blank" rel="noopener noreferrer" class="shine-topbar-mobile-icon text-decoration-none" aria-label="Instagram" title="Instagram">
                        <i class="fab fa-instagram"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="shine-topbar d-none d-lg-block">
        <div class="container-fluid px-3 px-md-4">
            <div class="row align-items-center py-2 gx-3">
                <div class="col shine-topbar-col-main">
                    <div class="shine-topbar-links d-flex align-items-center">
                        <a href="https://maps.app.goo.gl/S5UGHhxQ6fssKRFM7" class="shine-topbar-link text-decoration-none d-inline-flex align-items-center">
                            <i class="fas fa-map-marker-alt text-primary me-2"></i>
                            <span>Івано-Франківськ, вул. Кармелюка, 30</span>
                        </a>
                        <span class="shine-topbar-divider" aria-hidden="true"></span>
                        <a href="tel:+380669052664" class="shine-topbar-link text-decoration-none d-inline-flex align-items-center">
                            <i class="fas fa-phone-alt text-primary me-2"></i>
                            <span>+380 66 905 26 64</span>
                        </a>
                        <span class="shine-topbar-divider" aria-hidden="true"></span>
                        <a href="mailto:shine.cosmetologybyzelinska@gmail.com" class="shine-topbar-link shine-topbar-link-mail text-decoration-none d-inline-flex align-items-center">
                            <i class="fas fa-envelope text-primary me-2 flex-shrink-0"></i>
                            <span class="text-truncate">shine.cosmetologybyzelinska@gmail.com</span>
                        </a>
                    </div>
                </div>
                <div class="col-auto">
                    <div class="d-flex align-items-center gap-2">
                        <a href="https://facebook.com" target="_blank" rel="noopener noreferrer" class="shine-social text-decoration-none" aria-label="Facebook">
                            <i class="fab fa-facebook-f small"></i>
                        </a>
                        <a href="https://instagram.com/shinee.cosmetology" target="_blank" rel="noopener noreferrer" class="shine-social text-decoration-none" aria-label="Instagram">
                            <i class="fab fa-instagram small"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="shine-header-chrome border-bottom bg-white shadow-sm">
        <div class="container-fluid px-2 px-sm-3 py-2 d-flex align-items-center justify-content-between gap-2">
            <div class="d-flex align-items-center gap-2 min-w-0">
                <button type="button"
                        class="btn btn-light border rounded-3 d-lg-none shine-menu-btn"
                        data-bs-toggle="offcanvas"
                        data-bs-target="#shineNavDrawer"
                        aria-controls="shineNavDrawer"
                        aria-label="Відкрити меню">
                    <i class="bi bi-list fs-4" aria-hidden="true"></i>
                </button>
                <span class="d-lg-none text-truncate small text-secondary fw-semibold">Меню</span>
            </div>
            <div class="d-flex align-items-center gap-2 flex-shrink-0">
                <a href="/cart" class="shine-cart shine-cart-nav position-relative text-decoration-none p-2 rounded-3" aria-label="Кошик">
                    <i class="bi bi-cart3 fs-5"></i>
                    @if (cartCount > 0)
                    {
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger shine-cart-badge">@cartCount</span>
                    }
                </a>
                <a href="/appointment-user" class="btn btn-primary rounded-pill shine-cta text-white text-decoration-none d-none d-sm-inline-flex px-3">
                    Записатися
                </a>
                <a href="/appointment-user" class="btn btn-primary rounded-3 shine-cta text-white d-sm-none p-2" aria-label="Записатися">
                    <i class="bi bi-calendar-plus fs-5" aria-hidden="true"></i>
                </a>
            </div>
        </div>
    </div>
</header>

@code {
    private int cartCount;

    protected override async Task OnInitializedAsync()
    {
        _cartService.CartCountChanged += OnCartCountChanged;
        await _cartService.NotifyCountChangedAsync();
    }

    private void OnCartCountChanged(int count)
    {
        cartCount = count;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        _cartService.CartCountChanged -= OnCartCountChanged;
    }
}

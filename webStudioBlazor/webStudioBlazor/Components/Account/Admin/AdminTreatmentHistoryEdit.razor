@page "/admin/treatment-history/edit/{Id:int}"
@layout AdminLayout
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.WebUtilities
@inject TreatmentHistoryService TreatmentSvc
@inject NavigationManager Nav
@inject IJSRuntime Js

<div class="container shine-admin-3d-page pb-5">
    @if (notFound)
    {
        <p class="text-muted">Запис не знайдено.</p>
        <a class="btn btn-outline-secondary rounded-pill" href="/admin-clients">До календаря</a>
    }
    else if (entity is null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-danger" role="status"><span class="visually-hidden">Завантаження</span></div>
        </div>
    }
    else
    {
        <header class="shine-admin-page-hero text-center text-lg-start mb-4">
            <span class="shine-admin-page-kicker">Редагування</span>
            <h1 class="shine-admin-page-title mb-0">@form.ProcedureName</h1>
            <p class="shine-admin-page-lead mb-0 mt-2">Клієнт: <code class="small">@entity.ClientId</code></p>
        </header>

        <div class="card border-0 shadow-sm rounded-4 th-form-card mb-4">
            <div class="card-body p-4">
                @if (!string.IsNullOrEmpty(errorMsg))
                {
                    <div class="alert alert-danger" role="alert">@errorMsg</div>
                }

                <EditForm Model="form" OnValidSubmit="SaveAsync">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="text-danger mb-3" />

                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Дата відвідування</label>
                            <InputDate class="form-control" @bind-Value="form.VisitDate" TValue="DateTime" />
                            <ValidationMessage For="() => form.VisitDate" class="text-danger small d-block" />
                        </div>
                        <div class="col-md-8">
                            <label class="form-label fw-semibold">Назва процедури</label>
                            <InputText class="form-control" @bind-Value="form.ProcedureName" autocomplete="off" />
                            <ValidationMessage For="() => form.ProcedureName" class="text-danger small d-block" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Опис процедури</label>
                        <InputTextArea class="form-control" rows="4" @bind-Value="form.ProcedureDescription" />
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Стан шкіри до процедури</label>
                            <InputTextArea class="form-control" rows="3" @bind-Value="form.SkinBeforeDescription" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Стан шкіри після процедури</label>
                            <InputTextArea class="form-control" rows="3" @bind-Value="form.SkinAfterDescription" />
                        </div>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Рекомендації після процедури</label>
                            <InputTextArea class="form-control" rows="3" @bind-Value="form.Recommendations" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Коментар майстра</label>
                            <InputTextArea class="form-control" rows="3" @bind-Value="form.MasterComment" />
                        </div>
                    </div>

                    <div class="d-flex flex-wrap gap-2">
                        <button type="submit" class="btn rounded-pill th-btn-primary px-4" disabled="@saving">
                            @if (saving)
                            {
                                <span class="spinner-border spinner-border-sm me-1" aria-hidden="true"></span>
                            }
                            Зберегти зміни
                        </button>
                        <a class="btn btn-outline-secondary rounded-pill" href="@BackUrl">Назад до історії</a>
                    </div>
                </EditForm>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4 th-form-card mb-4">
            <div class="card-body p-4">
                <h2 class="h6 fw-bold mb-3">Фото на сервері</h2>
                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <span class="badge th-badge-before">До процедури</span>
                        </div>
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var p in beforePhotos)
                            {
                                <div class="position-relative th-edit-thumb-wrap">
                                    <img src="@PhotoUrl(p.FilePath)" class="th-thumb rounded-3 border" alt="" />
                                    <button type="button" class="btn btn-sm btn-danger position-absolute top-0 end-0 m-1 py-0 px-1" title="Видалити" @onclick="() => DeletePhotoAsync(p)">×</button>
                                </div>
                            }
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <span class="badge th-badge-after">Після процедури</span>
                        </div>
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var p in afterPhotos)
                            {
                                <div class="position-relative th-edit-thumb-wrap">
                                    <img src="@PhotoUrl(p.FilePath)" class="th-thumb rounded-3 border" alt="" />
                                    <button type="button" class="btn btn-sm btn-danger position-absolute top-0 end-0 m-1 py-0 px-1" title="Видалити" @onclick="() => DeletePhotoAsync(p)">×</button>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <hr class="my-4" />

                <h2 class="h6 fw-bold mb-3">Додати фото</h2>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label small text-muted">Нові фото «до»</label>
                        <InputFile class="form-control" multiple accept="image/*" OnChange="OnBeforeChange" />
                        <p class="small text-muted mt-1 mb-0">@BeforeSummary</p>
                        @if (loadingBeforePreviews)
                        {
                            <div class="mt-2"><span class="spinner-border spinner-border-sm text-danger" role="status"></span> <span class="small text-muted">Обробка…</span></div>
                        }
                        else if (pendingBefore.Count > 0)
                        {
                            <div class="d-flex flex-wrap gap-2 mt-3 th-upload-preview-row">
                                @foreach (var p in pendingBefore)
                                {
                                    <div class="th-upload-preview-item text-center">
                                        @if (!string.IsNullOrEmpty(p.PreviewDataUrl))
                                        {
                                            <img src="@p.PreviewDataUrl" class="th-upload-preview-img rounded-3 border" alt="" />
                                        }
                                        else
                                        {
                                            <div class="th-upload-preview-placeholder rounded-3 border d-flex align-items-center justify-content-center small text-muted">?</div>
                                        }
                                        <div class="small text-truncate mt-1" style="max-width: 7.5rem" title="@p.FileName">@p.FileName</div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small text-muted">Нові фото «після»</label>
                        <InputFile class="form-control" multiple accept="image/*" OnChange="OnAfterChange" />
                        <p class="small text-muted mt-1 mb-0">@AfterSummary</p>
                        @if (loadingAfterPreviews)
                        {
                            <div class="mt-2"><span class="spinner-border spinner-border-sm text-danger" role="status"></span> <span class="small text-muted">Обробка…</span></div>
                        }
                        else if (pendingAfter.Count > 0)
                        {
                            <div class="d-flex flex-wrap gap-2 mt-3 th-upload-preview-row">
                                @foreach (var p in pendingAfter)
                                {
                                    <div class="th-upload-preview-item text-center">
                                        @if (!string.IsNullOrEmpty(p.PreviewDataUrl))
                                        {
                                            <img src="@p.PreviewDataUrl" class="th-upload-preview-img rounded-3 border" alt="" />
                                        }
                                        else
                                        {
                                            <div class="th-upload-preview-placeholder rounded-3 border d-flex align-items-center justify-content-center small text-muted">?</div>
                                        }
                                        <div class="small text-truncate mt-1" style="max-width: 7.5rem" title="@p.FileName">@p.FileName</div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>

                <div class="mt-3">
                    <button type="button" class="btn btn-outline-primary rounded-pill btn-sm" disabled="@(savingPhotos || (pendingBefore.Count == 0 && pendingAfter.Count == 0))" @onclick="UploadPendingAsync">
                        @if (savingPhotos)
                        {
                            <span class="spinner-border spinner-border-sm me-1" aria-hidden="true"></span>
                        }
                        Завантажити вибрані фото
                    </button>
                    <p class="small text-muted mt-2 mb-0">Фото з цього блоку також автоматично зберігаються при натисканні «Зберегти зміни» вище.</p>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }

    private TreatmentHistory? entity;
    private bool notFound;
    private readonly VisitForm form = new();
    private readonly List<PendingImage> pendingBefore = new();
    private readonly List<PendingImage> pendingAfter = new();
    private bool loadingBeforePreviews;
    private bool loadingAfterPreviews;
    private bool saving;
    private bool savingPhotos;
    private string? errorMsg;

    private string BackUrl => entity is null ? "/admin-clients" : $"/admin/treatment-history/{Uri.EscapeDataString(entity.ClientId)}";

    private IEnumerable<TreatmentPhoto> beforePhotos =>
        entity?.Photos.Where(p => string.Equals(p.PhotoType, TreatmentPhoto.PhotoTypeBefore, StringComparison.OrdinalIgnoreCase)).OrderBy(p => p.Id) ?? Enumerable.Empty<TreatmentPhoto>();

    private IEnumerable<TreatmentPhoto> afterPhotos =>
        entity?.Photos.Where(p => string.Equals(p.PhotoType, TreatmentPhoto.PhotoTypeAfter, StringComparison.OrdinalIgnoreCase)).OrderBy(p => p.Id) ?? Enumerable.Empty<TreatmentPhoto>();

    private string BeforeSummary => pendingBefore.Count == 0
        ? "Нічого не вибрано."
        : $"До завантаження: {pendingBefore.Count} (до {TreatmentHistoryService.MaxTreatmentImageUploadBytes / 1024 / 1024} МБ кожен).";

    private string AfterSummary => pendingAfter.Count == 0
        ? "Нічого не вибрано."
        : $"До завантаження: {pendingAfter.Count} (до {TreatmentHistoryService.MaxTreatmentImageUploadBytes / 1024 / 1024} МБ кожен).";

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
        TryShowPhotoErrFromQuery();
    }

    private void TryShowPhotoErrFromQuery()
    {
        try
        {
            var uri = new Uri(Nav.Uri);
            var q = QueryHelpers.ParseQuery(uri.Query);
            if (q.TryGetValue("photoErr", out var vals) && vals.Count > 0)
            {
                errorMsg = Uri.UnescapeDataString(vals.First() ?? "");
            }
        }
        catch
        {
            // ignore malformed query
        }
    }

    private async Task ReloadAsync()
    {
        entity = await TreatmentSvc.GetWithPhotosAsync(Id);
        if (entity is null)
        {
            notFound = true;
            return;
        }

        notFound = false;
        form.VisitDate = entity.VisitDate.ToLocalTime().Date;
        form.ProcedureName = entity.ProcedureName;
        form.ProcedureDescription = entity.ProcedureDescription;
        form.SkinBeforeDescription = entity.SkinBeforeDescription;
        form.SkinAfterDescription = entity.SkinAfterDescription;
        form.Recommendations = entity.Recommendations;
        form.MasterComment = entity.MasterComment;
    }

    private async Task OnBeforeChange(InputFileChangeEventArgs e)
    {
        loadingBeforePreviews = true;
        errorMsg = null;
        try
        {
            pendingBefore.Clear();
            foreach (var f in e.GetMultipleFiles(32))
            {
                await using var stream = f.OpenReadStream(maxAllowedSize: TreatmentHistoryService.MaxTreatmentImageUploadBytes);
                using var ms = new MemoryStream();
                await stream.CopyToAsync(ms);
                var bytes = ms.ToArray();
                var preview = TreatmentHistoryService.TryGetPreviewDataUrlFromBytes(bytes);
                var item = new PendingImage(f.Name, bytes, preview);
                pendingBefore.Add(item);
            }
        }
        catch (Exception ex)
        {
            errorMsg = $"Фото «до»: {ex.Message}";
        }
        finally
        {
            loadingBeforePreviews = false;
        }
    }

    private async Task OnAfterChange(InputFileChangeEventArgs e)
    {
        loadingAfterPreviews = true;
        errorMsg = null;
        try
        {
            pendingAfter.Clear();
            foreach (var f in e.GetMultipleFiles(32))
            {
                await using var stream = f.OpenReadStream(maxAllowedSize: TreatmentHistoryService.MaxTreatmentImageUploadBytes);
                using var ms = new MemoryStream();
                await stream.CopyToAsync(ms);
                var bytes = ms.ToArray();
                var preview = TreatmentHistoryService.TryGetPreviewDataUrlFromBytes(bytes);
                var item = new PendingImage(f.Name, bytes, preview);
                pendingAfter.Add(item);
            }
        }
        catch (Exception ex)
        {
            errorMsg = $"Фото «після»: {ex.Message}";
        }
        finally
        {
            loadingAfterPreviews = false;
        }
    }

    private async Task SaveAsync()
    {
        if (entity is null) return;
        saving = true;
        errorMsg = null;
        try
        {
            var visitUtc = DateTime.SpecifyKind(form.VisitDate.Date, DateTimeKind.Local).ToUniversalTime();
            var patch = new TreatmentHistory
            {
                Id = entity.Id,
                ClientId = entity.ClientId,
                VisitDate = visitUtc,
                ProcedureName = form.ProcedureName.Trim(),
                ProcedureDescription = form.ProcedureDescription.Trim(),
                SkinBeforeDescription = form.SkinBeforeDescription.Trim(),
                SkinAfterDescription = form.SkinAfterDescription.Trim(),
                Recommendations = form.Recommendations.Trim(),
                MasterComment = form.MasterComment.Trim()
            };

            var ok = await TreatmentSvc.UpdateDetailsAsync(patch);
            if (!ok)
            {
                errorMsg = "Не вдалося зберегти зміни.";
                return;
            }

            var flushErrors = await TryFlushPendingPhotosAsync();
            if (flushErrors.Count > 0)
            {
                errorMsg = string.Join(" · ", flushErrors);
                return;
            }

            Nav.NavigateTo(BackUrl);
        }
        catch (Exception ex)
        {
            errorMsg = ex.Message;
        }
        finally
        {
            saving = false;
        }
    }

    private async Task DeletePhotoAsync(TreatmentPhoto p)
    {
        var ok = await Js.InvokeAsync<bool>("confirm", "Видалити це фото?");
        if (!ok) return;
        await TreatmentSvc.DeletePhotoAsync(p.Id);
        await ReloadAsync();
    }

    /// <summary>Зберігає вибрані фото; успішні прибирає зі списку, помилки повертає текстом.</summary>
    private async Task<IReadOnlyList<string>> TryFlushPendingPhotosAsync()
    {
        var errors = new List<string>();
        if (entity is null)
        {
            return errors;
        }

        foreach (var p in pendingBefore.ToList())
        {
            try
            {
                await TreatmentSvc.AddPhotoFromBytesAsync(entity.Id, entity.ClientId, TreatmentPhoto.PhotoTypeBefore, p.Bytes);
                pendingBefore.Remove(p);
            }
            catch (Exception ex)
            {
                errors.Add($"«До» {p.FileName}: {ex.Message}");
            }
        }

        foreach (var p in pendingAfter.ToList())
        {
            try
            {
                await TreatmentSvc.AddPhotoFromBytesAsync(entity.Id, entity.ClientId, TreatmentPhoto.PhotoTypeAfter, p.Bytes);
                pendingAfter.Remove(p);
            }
            catch (Exception ex)
            {
                errors.Add($"«Після» {p.FileName}: {ex.Message}");
            }
        }

        return errors;
    }

    private async Task UploadPendingAsync()
    {
        if (entity is null) return;
        savingPhotos = true;
        errorMsg = null;
        try
        {
            var errs = await TryFlushPendingPhotosAsync();
            if (errs.Count > 0)
            {
                errorMsg = string.Join(" · ", errs);
            }

            await ReloadAsync();
        }
        catch (Exception ex)
        {
            errorMsg = ex.Message;
        }
        finally
        {
            savingPhotos = false;
        }
    }

    private string PhotoUrl(string? path)
    {
        if (string.IsNullOrWhiteSpace(path))
        {
            return string.Empty;
        }

        var p = path.Trim();
        if (p.StartsWith("http://", StringComparison.OrdinalIgnoreCase)
            || p.StartsWith("https://", StringComparison.OrdinalIgnoreCase)
            || p.StartsWith("data:", StringComparison.OrdinalIgnoreCase))
        {
            return p;
        }

        var rel = p.StartsWith('/') ? p : "/" + p;
        return Nav.ToAbsoluteUri(rel).AbsoluteUri;
    }

    private sealed class VisitForm
    {
        [Required]
        public DateTime VisitDate { get; set; }

        [Required]
        [StringLength(400, MinimumLength = 2)]
        public string ProcedureName { get; set; } = "";

        [StringLength(8000)]
        public string ProcedureDescription { get; set; } = "";

        [StringLength(8000)]
        public string SkinBeforeDescription { get; set; } = "";

        [StringLength(8000)]
        public string SkinAfterDescription { get; set; } = "";

        [StringLength(8000)]
        public string Recommendations { get; set; } = "";

        [StringLength(8000)]
        public string MasterComment { get; set; } = "";
    }

    private sealed record PendingImage(string FileName, byte[] Bytes, string? PreviewDataUrl);
}

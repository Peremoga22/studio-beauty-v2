@page "/edit-cosmetology"
@page "/edit-cosmetology/{Id:int}"

@inject SeedService _seedService
@inject IWebHostEnvironment Env
@inject NavigationManager _navigationManager
@inject IJSRuntime _jSRuntime
@layout AdminLayout
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer

<div class="container shine-admin-3d-page pb-4">
    <nav class="shine-edit-cosmo-breadcrumb mb-4" aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a class="shine-edit-cosmo-back" href="/admin-cosmetology">
                    <i class="bi bi-arrow-left-short" aria-hidden="true"></i>
                    Повернутися до адмін косметології
                </a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">@AddMessageTherapy</li>
        </ol>
    </nav>

    <section class="shine-edit-cosmo-form-card mb-5">
        <div class="shine-edit-cosmo-form-header">
            <i class="bi bi-journal-text" aria-hidden="true"></i>
            <strong>@(Id == 0 ? "Додати картку" : "Редагувати картку")</strong>
        </div>

        <EditForm Model="@therapyCard"
                  OnValidSubmit="SaveTherapyCardAsync"
                  class="shine-edit-cosmo-form-body">
            <DataAnnotationsValidator />
            <ValidationSummary class="shine-edit-cosmo-validation" />

            <h2 class="shine-edit-cosmo-form-title">
                @(therapyCard.Id == 0 ? "Додати нову картку" : "Редагувати картку")
            </h2>

            <div class="shine-edit-cosmo-field">
                <label for="TitleCard" class="shine-edit-cosmo-label">
                    Назва картки <span class="text-danger">*</span>
                </label>
                <InputText id="TitleCard"
                           @bind-Value="therapyCard.TitleCard"
                           class="form-control shine-edit-cosmo-input"
                           placeholder="Введіть назву..." />
                <ValidationMessage For="@(() => therapyCard.TitleCard)" class="shine-edit-cosmo-error" />
            </div>

            <div class="shine-edit-cosmo-field">
                <label for="DescriptionCard" class="shine-edit-cosmo-label">
                    Опис картки <span class="text-danger">*</span>
                </label>
                <InputText id="DescriptionCard"
                           @bind-Value="therapyCard.DescriptionCard"
                           class="form-control shine-edit-cosmo-input"
                           placeholder="Короткий опис..." />
                <ValidationMessage For="@(() => therapyCard.DescriptionCard)" class="shine-edit-cosmo-error" />
            </div>

            <div class="shine-edit-cosmo-field">
                <label for="Price" class="shine-edit-cosmo-label">
                    Ціна за послугу <span class="text-danger">*</span>
                </label>
                <div class="input-group shine-edit-cosmo-price-group">
                    <span class="input-group-text">₴</span>
                    <InputNumber id="Price"
                                 @bind-Value="therapyCard.Price"
                                 class="form-control shine-edit-cosmo-input"
                                 placeholder="0" />
                </div>
                <small class="shine-edit-cosmo-hint">Вкажіть вартість у гривнях.</small>
                <ValidationMessage For="@(() => therapyCard.Price)" class="shine-edit-cosmo-error" />
            </div>

            <div class="shine-edit-cosmo-field">
                <label class="shine-edit-cosmo-label">
                    Вибрати категорію для сторінки <span class="text-danger">*</span>
                </label>
                @if (!string.IsNullOrEmpty(ErrorMessageCategory))
                {
                    <p class="shine-edit-cosmo-error mb-2">@ErrorMessageCategory</p>
                }
                <InputSelect class="form-select shine-edit-cosmo-input" TValue="int" @bind-Value="therapyCard.CategoryId">
                    <option value="0">Оберіть категорію</option>
                    @foreach (var item in categories)
                    {
                        <option value="@item.Id">@item.NameCategory</option>
                    }
                </InputSelect>
            </div>

            <div class="shine-edit-cosmo-field mb-0">
                <label class="shine-edit-cosmo-label">Фото (jpg/jpeg/png)</label>
                <InputFile OnChange="OnFileSelected"
                           class="form-control shine-edit-cosmo-input"
                           accept=".jpg,.jpeg,.png" />
                @if (!string.IsNullOrEmpty(therapyCard.ImagePath))
                {
                    <div class="shine-edit-cosmo-preview mt-3">
                        <img src="@therapyCard.ImagePath"
                             alt="Попередній перегляд"
                             class="shine-edit-cosmo-preview-img" />
                    </div>
                }
            </div>

            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <p class="shine-edit-cosmo-error mt-3 mb-0">@ErrorMessage</p>
            }

            <div class="shine-edit-cosmo-actions">
                @if (therapyCard.Id > 0)
                {
                    <button type="button"
                            class="shine-edit-cosmo-btn shine-edit-cosmo-btn--danger"
                            @onclick="() => DeleteTherapyCardAsync(therapyCard.Id)">
                        <i class="bi bi-trash" aria-hidden="true"></i>
                        <span class="d-none d-sm-inline">Видалити</span>
                    </button>
                }
                <button type="submit" class="shine-edit-cosmo-btn shine-edit-cosmo-btn--primary">
                    <i class="bi bi-save" aria-hidden="true"></i>
                    <span class="d-none d-sm-inline">Зберегти</span>
                </button>
                <button type="button"
                        class="shine-edit-cosmo-btn shine-edit-cosmo-btn--ghost"
                        @onclick="CancelTherapyCard">
                    <i class="bi bi-x-circle" aria-hidden="true"></i>
                    <span class="d-none d-sm-inline">Скасувати</span>
                </button>
            </div>
        </EditForm>
    </section>

    <section class="shine-edit-cosmo-grid-section">
        <h3 class="shine-edit-cosmo-grid-title">
            <i class="bi bi-grid-3x3-gap" aria-hidden="true"></i>
            Картки послуг
        </h3>
        <div class="row g-3">
            @{
                var page = pageTherapies.FirstOrDefault(p => p.TitlePage == selectedCosmetology);
            }
            @foreach (var item in therapyCards.Where(x => x.CategoryId == page?.CategoryId))
            {
                <div class="col-6 col-lg-3">
                    <article class="shine-edit-cosmo-product h-100">
                        <div class="shine-edit-cosmo-product-image ratio ratio-1x1">
                            <img src="@item.ImagePath"
                                 alt="@item.TitleCard"
                                 class="object-fit-cover"
                                 loading="lazy" />
                        </div>
                        <div class="shine-edit-cosmo-product-body">
                            <h4 class="shine-edit-cosmo-product-title" title="@item.TitleCard">@item.TitleCard</h4>
                            <p class="shine-edit-cosmo-product-desc" title="@item.DescriptionCard">@item.DescriptionCard</p>
                            <div class="shine-edit-cosmo-product-footer">
                                <button type="button"
                                        class="shine-edit-cosmo-edit-btn"
                                        @onclick="() => EdittherapyCard(item.Id)">
                                    <i class="bi bi-pencil-square" aria-hidden="true"></i>
                                    Редагувати
                                </button>
                                <span class="shine-edit-cosmo-price">
                                    @item.Price.ToString("N0", new System.Globalization.CultureInfo("uk-UA")) ₴
                                </span>
                            </div>
                        </div>
                    </article>
                </div>
            }
        </div>
    </section>
</div>

@code {
    [Parameter]
    public int Id { get; set; }
    private string AddMessageTherapy = "Додати категорію";
    private TherapyCard therapyCard = new();

    private List<Category> categories = new();
    private List<PageTherapy> pageTherapies = new();
    private List<TherapyCard> therapyCards = new();

    private string ErrorMessageCategory = string.Empty;
    private string ErrorMessage = string.Empty;
    private IBrowserFile? uploadedFile;
    private const long maxSize = 5 * 1024 * 1024;
    private const string UploadsSubfolder = "uploads/cosmetology";
    private string selectedCosmetology = "Косметологія";

    protected override async Task OnInitializedAsync()
    {
        therapyCards = await _seedService.GetAllTherapyCardListAsync();
        pageTherapies = await _seedService.GetAllPageTherapyListAsync();
        categories = await _seedService.GetAllCategoryListAsync();

        if (Id > 0)
        {
            therapyCard = await _seedService.EditTherapyCard(Id);
            AddMessageTherapy = "Редагувати картку";
        }
    }

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        uploadedFile = e.File;
    }

    private async Task SaveTherapyCardAsync()
    {
        if (uploadedFile is not null)
        {
            var ext = Path.GetExtension(uploadedFile.Name)?.ToLowerInvariant();
            var allowed = new HashSet<string>(StringComparer.OrdinalIgnoreCase) { ".jpg", ".jpeg", ".png", ".webp" };
            if (string.IsNullOrWhiteSpace(ext) || !allowed.Contains(ext))
                throw new InvalidOperationException("Дозволені формати: JPG, JPEG, PNG, WEBP.");

            if (uploadedFile.Size > maxSize)
                throw new InvalidOperationException("Файл завеликий (максимум 5 МБ).");

            var webRoot = Env.WebRootPath ?? throw new InvalidOperationException("WebRootPath недоступний.");

            var safeSubfolder = (UploadsSubfolder ?? "uploads")
                .Trim()
                .TrimStart(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar);

            if (safeSubfolder.Contains(".."))
                throw new InvalidOperationException("Некоректний підкаталог для завантажень.");

            var physicalFolder = Path.Combine(webRoot, safeSubfolder);
            Directory.CreateDirectory(physicalFolder);

            var fileName = $"{Guid.NewGuid():N}{ext}";
            var physicalPath = Path.Combine(physicalFolder, fileName);

            await using (var fs = new FileStream(physicalPath, FileMode.Create, FileAccess.Write, FileShare.Read, 81920, useAsync: true))
            {
                await uploadedFile.OpenReadStream(maxSize).CopyToAsync(fs);
            }

            if (!string.IsNullOrEmpty(therapyCard.ImagePath))
            {
                var oldRel = therapyCard.ImagePath.TrimStart('/', '\\')
                    .Replace('/', Path.DirectorySeparatorChar);

                if (!oldRel.Contains(".."))
                {
                    var oldPhysical = Path.Combine(webRoot, oldRel);
                    try { if (System.IO.File.Exists(oldPhysical)) System.IO.File.Delete(oldPhysical); } catch (Exception ex) { ErrorMessage = $"Помилка при видаленні: {ex.Message}"; }
                }
            }

            therapyCard.ImagePath = $"/{safeSubfolder.Replace("\\", "/")}/{fileName}";
        }

        if (string.IsNullOrWhiteSpace(therapyCard.TitleCard)
          || string.IsNullOrWhiteSpace(therapyCard.DescriptionCard)
          || therapyCard.Price <= 0
          || therapyCard.CategoryId == 0
          || string.IsNullOrWhiteSpace(therapyCard.ImagePath))
        {
            return;
        }

        await _seedService.SaveCosmetologyTherapyCardAsync(therapyCard);
        therapyCards = await _seedService.GetAllTherapyCardListAsync();
        therapyCard = new();
        StateHasChanged();
    }

    private async Task EdittherapyCard(int id)
    {
        therapyCard = await _seedService.EditTherapyCard(id);
        AddMessageTherapy = "Редагувати картку";
    }

    private async Task DeleteTherapyCardAsync(int cardId)
    {
        try
        {
            if (!string.IsNullOrEmpty(therapyCard.ImagePath))
            {
                var webRoot = Env.WebRootPath ?? throw new InvalidOperationException("WebRootPath недоступний.");
                var relative = therapyCard.ImagePath.TrimStart('/').Replace('/', Path.DirectorySeparatorChar);
                var physicalPath = Path.Combine(webRoot, relative);

                if (System.IO.File.Exists(physicalPath))
                {
                    System.IO.File.Delete(physicalPath);
                }

                await _seedService.DeleteTherapyCardAsync(cardId);
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Помилка при видаленні: {ex.Message}";
        }

        therapyCards = await _seedService.GetAllTherapyCardListAsync();
        therapyCard = new();
        StateHasChanged();
    }

    private void CancelTherapyCard()
    {
        therapyCard = new();
        StateHasChanged();
    }
}

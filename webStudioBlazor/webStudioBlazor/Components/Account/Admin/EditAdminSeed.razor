@page "/edit-seed"
@page "/edit-seed/{Id:int}"
@inject NavigationManager _navigationManager
@inject SeedService _seedService
@layout AdminLayout
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]

<div class="container shine-admin-3d-page pb-4">
    <nav class="shine-edit-cosmo-breadcrumb" aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a class="shine-edit-cosmo-back" href="/admin-seed">Повернутися до наповнення</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">
                @(Id == 0 ? "Додавання даних" : "Редагування даних")
            </li>
        </ol>
    </nav>

    <!-- Майстер -->
    <section class="shine-edit-seed-section">
        <div class="shine-edit-cosmo-form-card">
            <div class="shine-edit-cosmo-form-header">
                <i class="bi bi-person-badge" aria-hidden="true"></i>
                <strong>@(Id == 0 ? "Додати майстра" : "Редагувати дані майстра")</strong>
            </div>
            <EditForm Model="@master" OnValidSubmit="SaveMaster">
                <DataAnnotationsValidator />
                <div class="shine-edit-cosmo-form-body">
                    <ValidationSummary class="shine-edit-cosmo-validation" />
                    <div class="row g-3">
                        <div class="col-12">
                            <label for="MasterFullName" class="shine-edit-cosmo-label">
                                ПІБ майстра <span class="text-danger">*</span>
                            </label>
                            <InputText id="MasterFullName"
                                       class="form-control shine-edit-cosmo-input"
                                       @bind-Value="master.FullName"
                                       placeholder="Напр., Оксана Ткачук" />
                            <ValidationMessage For="@(() => master.FullName)" class="shine-edit-cosmo-error" />
                        </div>
                        <div class="col-12">
                            <label for="MasterPhone" class="shine-edit-cosmo-label">
                                Мобільний <span class="text-danger">*</span>
                            </label>
                            <InputText id="MasterPhone"
                                       class="form-control shine-edit-cosmo-input"
                                       @bind-Value="master.Phone"
                                       placeholder="+380..." />
                            <ValidationMessage For="@(() => master.Phone)" class="shine-edit-cosmo-error" />
                        </div>
                    </div>
                    <div class="shine-edit-cosmo-actions">
                        <button type="submit" class="shine-edit-cosmo-btn shine-edit-cosmo-btn--primary">
                            <i class="bi bi-save" aria-hidden="true"></i>
                            <span class="d-none d-sm-inline">Зберегти</span>
                        </button>
                        <button type="button"
                                class="shine-edit-cosmo-btn shine-edit-cosmo-btn--ghost"
                                @onclick="CancelMaster">
                            <i class="bi bi-x-circle" aria-hidden="true"></i>
                            <span class="d-none d-sm-inline">Скасувати</span>
                        </button>
                    </div>
                </div>
            </EditForm>
        </div>

        <div class="shine-edit-seed-table-shell">
            <div class="table-responsive shine-edit-seed-table-wrap">
                <table class="table shine-edit-seed-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th scope="col">Майстер</th>
                            <th scope="col">Телефон</th>
                            <th scope="col" class="text-end">Дії</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (masters is null || masters.Count == 0)
                        {
                            <tr>
                                <td colspan="3" class="shine-edit-seed-empty text-center py-4">
                                    Немає жодного майстра. Додайте першого.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in masters)
                            {
                                <tr>
                                    <td class="fw-semibold">@item.FullName</td>
                                    <td>@item.Phone</td>
                                    <td class="text-end">
                                        <div class="d-flex justify-content-end gap-2 flex-wrap">
                                            <button type="button"
                                                    class="shine-edit-seed-edit-btn"
                                                    @onclick="() => EditMaster(item.Id)">
                                                <i class="bi bi-pencil-square" aria-hidden="true"></i>
                                                <span class="d-none d-sm-inline">Редагувати</span>
                                            </button>
                                            <button type="button"
                                                    class="shine-edit-seed-delete-btn"
                                                    @onclick="() => DeleteMaster(item.Id)">
                                                <i class="bi bi-trash" aria-hidden="true"></i>
                                                <span class="d-none d-sm-inline">Видалити</span>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </section>

    <!-- Категорія -->
    <section class="shine-edit-seed-section">
        <div class="shine-edit-cosmo-form-card">
            <div class="shine-edit-cosmo-form-header">
                <i class="bi bi-tags" aria-hidden="true"></i>
                <strong>@(Id == 0 ? "Додати категорію" : "Редагувати категорію")</strong>
            </div>
            <EditForm Model="@category" OnValidSubmit="SaveCategory" FormName="Category">
                <DataAnnotationsValidator />
                <div class="shine-edit-cosmo-form-body">
                    <ValidationSummary class="shine-edit-cosmo-validation" />
                    <div class="row g-3">
                        <div class="col-12">
                            <label for="NameCategory" class="shine-edit-cosmo-label">
                                Назва категорії <span class="text-danger">*</span>
                            </label>
                            <InputText id="NameCategory"
                                       class="form-control shine-edit-cosmo-input"
                                       @bind-Value="category.NameCategory"
                                       placeholder="Напр., Косметологія" />
                            <ValidationMessage For="@(() => category.NameCategory)" class="shine-edit-cosmo-error" />
                        </div>
                        <div class="col-12">
                            <label class="shine-edit-cosmo-label">
                                Вибрати майстра <span class="text-danger">*</span>
                            </label>
                            @if (!string.IsNullOrEmpty(ErrorMessageCategory))
                            {
                                <p class="shine-edit-cosmo-error mb-2">@ErrorMessageCategory</p>
                            }
                            <InputSelect class="form-select shine-edit-cosmo-input" TValue="int" @bind-Value="category.MasterId">
                                <option value="0">Оберіть майстра</option>
                                @foreach (var item in masters)
                                {
                                    <option value="@item.Id">@item.FullName</option>
                                }
                            </InputSelect>
                        </div>
                    </div>
                    <div class="shine-edit-cosmo-actions">
                        <button type="submit" class="shine-edit-cosmo-btn shine-edit-cosmo-btn--primary">
                            <i class="bi bi-save" aria-hidden="true"></i>
                            <span class="d-none d-sm-inline">Зберегти</span>
                        </button>
                        <button type="button"
                                class="shine-edit-cosmo-btn shine-edit-cosmo-btn--ghost"
                                @onclick="CancelCategory">
                            <i class="bi bi-x-circle" aria-hidden="true"></i>
                            <span class="d-none d-sm-inline">Скасувати</span>
                        </button>
                    </div>
                </div>
            </EditForm>
        </div>

        <div class="shine-edit-seed-table-shell">
            <div class="table-responsive shine-edit-seed-table-wrap">
                <table class="table shine-edit-seed-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th scope="col">Назва категорії</th>
                            <th scope="col">Назва майстра</th>
                            <th scope="col" class="text-end">Дії</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (categories is null || categories.Count == 0)
                        {
                            <tr>
                                <td colspan="3" class="shine-edit-seed-empty text-center py-4">
                                    Немає жодної категорії. Додайте першу.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in categories)
                            {
                                <tr>
                                    <td class="fw-semibold">@item.NameCategory</td>
                                    <td>@(item.Masters?.FullName ?? "—")</td>
                                    <td class="text-end">
                                        <div class="d-flex justify-content-end gap-2 flex-wrap">
                                            <button type="button"
                                                    class="shine-edit-seed-edit-btn"
                                                    @onclick="() => EditCategory(item.Id)">
                                                <i class="bi bi-pencil-square" aria-hidden="true"></i>
                                                <span class="d-none d-sm-inline">Редагувати</span>
                                            </button>
                                            <button type="button"
                                                    class="shine-edit-seed-delete-btn"
                                                    @onclick="() => DeleteCategory(item.Id)">
                                                <i class="bi bi-trash" aria-hidden="true"></i>
                                                <span class="d-none d-sm-inline">Видалити</span>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </section>

    <!-- Сторінка терапії -->
    <section class="shine-edit-seed-section mb-0">
        <div class="shine-edit-cosmo-form-card">
            <div class="shine-edit-cosmo-form-header">
                <i class="bi bi-journal-text" aria-hidden="true"></i>
                <strong>@(Id == 0 ? "Додати титульну сторінку терапії" : "Редагувати титульну сторінку терапії")</strong>
            </div>
            <EditForm Model="@pageTherapy" OnValidSubmit="SavePageTherapy">
                <DataAnnotationsValidator />
                <div class="shine-edit-cosmo-form-body">
                    <ValidationSummary class="shine-edit-cosmo-validation" />
                    <div class="row g-3">
                        <div class="col-12">
                            <label for="TitlePage" class="shine-edit-cosmo-label">
                                Назва сторінки <span class="text-danger">*</span>
                            </label>
                            <InputText id="TitlePage"
                                       class="form-control shine-edit-cosmo-input"
                                       @bind-Value="pageTherapy.TitlePage"
                                       placeholder="Напр., Класичний масаж" />
                            <ValidationMessage For="@(() => pageTherapy.TitlePage)" class="shine-edit-cosmo-error" />
                        </div>
                        <div class="col-12">
                            <label class="shine-edit-cosmo-label">
                                Вибрати категорію для сторінки <span class="text-danger">*</span>
                            </label>
                            @if (!string.IsNullOrEmpty(ErrorMessageCategory))
                            {
                                <p class="shine-edit-cosmo-error mb-2">@ErrorMessageCategory</p>
                            }
                            <InputSelect class="form-select shine-edit-cosmo-input" TValue="int" @bind-Value="pageTherapy.CategoryId">
                                <option value="0">Оберіть категорію</option>
                                @foreach (var item in categories)
                                {
                                    <option value="@item.Id">@item.NameCategory</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="col-12">
                            <label for="DescriptionPage" class="shine-edit-cosmo-label">
                                Опис сторінки <span class="text-danger">*</span>
                            </label>
                            <InputTextArea id="DescriptionPage"
                                           class="form-control shine-edit-cosmo-input"
                                           @bind-Value="pageTherapy.DescriptionPage"
                                           rows="3"
                                           placeholder="Короткий опис..." />
                            <ValidationMessage For="@(() => pageTherapy.DescriptionPage)" class="shine-edit-cosmo-error" />
                        </div>
                    </div>
                    <div class="shine-edit-cosmo-actions">
                        <button type="submit" class="shine-edit-cosmo-btn shine-edit-cosmo-btn--primary">
                            <i class="bi bi-save" aria-hidden="true"></i>
                            <span class="d-none d-sm-inline">Зберегти</span>
                        </button>
                        <button type="button"
                                class="shine-edit-cosmo-btn shine-edit-cosmo-btn--ghost"
                                @onclick="CancelPageTherapy">
                            <i class="bi bi-x-circle" aria-hidden="true"></i>
                            <span class="d-none d-sm-inline">Скасувати</span>
                        </button>
                    </div>
                </div>
            </EditForm>
        </div>

        <div class="shine-edit-seed-table-shell">
            <div class="table-responsive shine-edit-seed-table-wrap">
                <table class="table shine-edit-seed-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th scope="col">Назва сторінки</th>
                            <th scope="col">Опис сторінки</th>
                            <th scope="col" class="text-end">Дії</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (pageTherapies is null || pageTherapies.Count == 0)
                        {
                            <tr>
                                <td colspan="3" class="shine-edit-seed-empty text-center py-4">
                                    Немає сторінок терапій. Додайте першу.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in pageTherapies)
                            {
                                <tr>
                                    <td class="fw-semibold">@item.TitlePage</td>
                                    <td class="text-muted text-truncate" style="max-width: 520px">@item.DescriptionPage</td>
                                    <td class="text-end">
                                        <div class="d-flex justify-content-end gap-2 flex-wrap">
                                            <button type="button"
                                                    class="shine-edit-seed-edit-btn"
                                                    @onclick="() => EditPageTherapy(item.Id)">
                                                <i class="bi bi-pencil-square" aria-hidden="true"></i>
                                                <span class="d-none d-sm-inline">Редагувати</span>
                                            </button>
                                            <button type="button"
                                                    class="shine-edit-seed-delete-btn"
                                                    @onclick="() => DeletePageTherapy(item.Id)">
                                                <i class="bi bi-trash" aria-hidden="true"></i>
                                                <span class="d-none d-sm-inline">Видалити</span>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="shine-edit-seed-roles-row">
            <button type="button"
                    class="shine-edit-cosmo-btn shine-edit-cosmo-btn--danger"
                    @onclick="GoToRoles">
                <i class="bi bi-person-lines-fill" aria-hidden="true"></i>
                <span class="d-none d-sm-inline">Перейти до присвоєння ролей</span>
            </button>
        </div>
    </section>
</div>

@code {
    [Parameter]
    public int Id { get; set; }
    private Master master = new();
    private Category category = new();
    private PageTherapy pageTherapy = new();
    private TherapyCard therapyCard = new();

    private List<Master> masters = new();
    private List<Category> categories = new();
    private List<PageTherapy> pageTherapies = new();

    private string ErrorMessageCategory = string.Empty;
    private string ErrorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        masters = await _seedService.GetAllMasterListAsync();
        categories = await _seedService.GetAllCategoryListAsync();
        pageTherapies = await _seedService.GetAllPageTherapyListAsync();
    }

    private async Task SaveMaster()
    {
        await _seedService.SaveSeedMasterAsync(master);
        master = new();
        masters = await _seedService.GetAllMasterListAsync();
        categories = await _seedService.GetAllCategoryListAsync();
        StateHasChanged();
    }

    private async Task SaveCategory()
    {
        await _seedService.SaveSeedCategoryAsync(category);
        category = new();
        categories = await _seedService.GetAllCategoryListAsync();
        StateHasChanged();
    }

    private async Task SavePageTherapy()
    {
        await _seedService.SaveSeedPageTherapyAsync(pageTherapy);
        pageTherapy = new();
        pageTherapies = await _seedService.GetAllPageTherapyListAsync();
        StateHasChanged();
    }

    private async Task SaveTherapyCardAsync()
    {
        await _seedService.SaveCosmetologyTherapyCardAsync(therapyCard);
        therapyCard = new();
        StateHasChanged();
    }

    private async Task EditMaster(int id)
    {
        master = await _seedService.EditMaster(id);
    }

    private async Task EditCategory(int id)
    {
        category = await _seedService.EditCategory(id);
    }

    private async Task EditPageTherapy(int id)
    {
        pageTherapy = await _seedService.EditPageTherapy(id);
    }

    private async Task EdittherapyCard(int id)
    {
        therapyCard = await _seedService.EditTherapyCard(id);
    }

    private async Task DeleteMaster(int id)
    {
        await _seedService.DeleteMasterAsync(id);
        masters = await _seedService.GetAllMasterListAsync();
        StateHasChanged();
    }

    public async Task DeleteCategory(int id)
    {
        await _seedService.DeleteCategoryAsync(id);
        categories = await _seedService.GetAllCategoryListAsync();
        StateHasChanged();
    }

    private async Task DeletePageTherapy(int id)
    {
        await _seedService.DeletePageTherapyAsync(id);
        pageTherapies = await _seedService.GetAllPageTherapyListAsync();
        StateHasChanged();
    }

    private void CancelMaster()
    {
        master = new();
        StateHasChanged();
    }

    private void CancelCategory()
    {
        category = new();
        StateHasChanged();
    }

    private void CancelPageTherapy()
    {
        pageTherapy = new();
        StateHasChanged();
    }

    private void GoToRoles()
    {
        _navigationManager.NavigateTo("/admin/roles");
    }
}

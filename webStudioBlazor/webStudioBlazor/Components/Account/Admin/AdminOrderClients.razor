@page "/admin-order-clients"

@inject SeedService _seedService
@inject NavigationManager _navigationManager
@inject OrderService _orderService
@layout AdminLayout
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer

<div class="container shine-admin-3d-page pb-4">
    <header class="shine-admin-page-hero text-center text-lg-start mb-4">
        <span class="shine-admin-page-kicker">Магазин</span>
        <h1 class="shine-admin-page-title mb-0">Список замовлень</h1>
        <p class="shine-admin-page-lead mb-0 mt-2">Переглядайте та керуйте замовленнями клієнтів студії SHINE.</p>
    </header>

    <div class="orders-card">
        <header class="shine-admin-orders-card-header">
            <h2 class="shine-admin-card-title mb-1">Замовлення</h2>
            <p class="shine-admin-card-subtitle mb-0">Доставка, контакти та склад замовлення</p>
        </header>

        <div class="divider shine-admin-divider shine-admin-orders-divider"></div>

        @if (rows.Count == 0)
        {
            <div class="shine-admin-empty rounded-4 p-4 text-center">Немає замовлень</div>
        }
        else
        {
            @foreach (var r in rows.Where(c => c.IsShownInOrder == true))
            {
                <article class="order-item shine-admin-order-entry">
                    <div class="order-item__info">
                        <span class="time text-muted shine-admin-order-time d-inline-flex align-items-center gap-1">
                            <i class="bi bi-calendar3 shine-admin-order-icon" aria-hidden="true"></i>
                            @r.OrderDate.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                        </span>

                        <div class="client fw-semibold shine-admin-order-client d-flex align-items-center gap-2">
                            <i class="bi bi-person-circle shine-admin-order-icon" aria-hidden="true"></i>
                            <span>@r.FirstName @r.LastName</span>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(r.Phone))
                        {
                            <a href="tel:@r.Phone" class="shine-admin-order-phone d-inline-flex align-items-center gap-2">
                                <i class="bi bi-telephone shine-admin-order-icon" aria-hidden="true"></i>
                                <span>@r.Phone</span>
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">Телефон не вказано</span>
                        }

                        @if (!string.IsNullOrWhiteSpace(r.ItemName))
                        {
                            <p class="shine-admin-order-product mb-0">
                                <span class="fw-semibold">@r.ItemName</span>
                                @if (r.MoreItemsCount > 0)
                                {
                                    <span class="text-muted"> • ще @r.MoreItemsCount</span>
                                }
                            </p>
                        }
                        else
                        {
                            <p class="text-muted mb-0">Товар не знайдено</p>
                        }

                        <div class="meta text-muted shine-admin-order-meta">
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-geo-alt-fill shine-admin-order-icon" aria-hidden="true"></i>
                                <span>@r.City</span>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-box-seam shine-admin-order-icon" aria-hidden="true"></i>
                                <span>@r.NewPostOffice</span>
                            </div>
                        </div>
                    </div>

                    <div class="order-item__aside">
                        <div class="price d-flex flex-column text-md-end">
                            <div class="fw-semibold shine-admin-order-price-line">
                                @r.Quantity × @r.UnitPrice.ToString("C0", OrderPage.ua)
                            </div>
                            <div class="shine-admin-order-total fw-bold">
                                = @r.LineTotal.ToString("C0", OrderPage.ua)
                            </div>
                            <div class="order-total text-muted shine-admin-order-order-total">
                                Разом по замовленню: @r.OrderTotal.ToString("C0", OrderPage.ua)
                            </div>
                        </div>
                        <div class="card-actions text-center text-md-end mt-2">
                            <button type="button"
                                    class="btn btn-outline-danger btn-sm rounded-pill d-inline-flex align-items-center gap-1 px-3 py-1 shine-admin-order-delete-btn"
                                    @onclick="() => DeleteOrder(r.OrderItemId)">
                                <i class="bi bi-trash" aria-hidden="true"></i>
                                <span>Видалити</span>
                            </button>
                        </div>
                    </div>
                </article>
            }
        }
    </div>
</div>

@code {
    private List<OrderRow> rows = new();

    protected override async Task OnInitializedAsync()
    {
        rows = await _orderService.ListCardsAsync();
    }

    static class OrderPage
    {
        public static readonly CultureInfo ua = new("uk-UA");
    }

    private async Task DeleteOrder(int id)
    {
        await _orderService.DeleteOrderAsync(id);
        rows.RemoveAll(r => r.OrderItemId == id);
    }
}

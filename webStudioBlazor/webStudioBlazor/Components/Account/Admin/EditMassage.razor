@page "/edit-massage-therapy"
@page "/edit-massage-therapy/{Id:int}"

@inject SeedService _seedService
@inject IWebHostEnvironment Env
@inject NavigationManager _navigationManager
@inject IJSRuntime _jSRuntime
@layout AdminLayout
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer

<div class="container shine-admin-3d-page pb-4">
    <nav class="shine-edit-cosmo-breadcrumb mb-4" aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a class="shine-edit-cosmo-back" href="/admin-massage-therapy">
                    <i class="bi bi-arrow-left-short" aria-hidden="true"></i>
                    Повернутися до адмін масажної терапії
                </a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">@AddMessageTherapy</li>
        </ol>
    </nav>

    <section class="add-card-wrapper mb-5">
        <div class="add-card-header">
            <i class="bi bi-journal-text" aria-hidden="true"></i>
            <span>@(Id == 0 ? "Додати картку" : "Редагувати картку")</span>
        </div>

        <EditForm Model="@therapyCard"
                  OnValidSubmit="SaveTherapyCardAsync">
            <DataAnnotationsValidator />
            <ValidationSummary class="shine-edit-cosmo-validation" />

            <h2 class="add-card-subtitle">
                @(therapyCard.Id == 0 ? "Додати нову картку" : "Редагувати картку")
            </h2>

            <div class="form-grid">
                <div class="form-group">
                    <label for="TitleCard" class="form-label">
                        Назва картки <span class="text-danger">*</span>
                    </label>
                    <InputText id="TitleCard"
                               @bind-Value="therapyCard.TitleCard"
                               class="form-control"
                               placeholder="Введіть назву..." />
                    <ValidationMessage For="@(() => therapyCard.TitleCard)" class="shine-edit-cosmo-error" />
                </div>

                <div class="form-group">
                    <label for="DescriptionCard" class="form-label">
                        Опис картки <span class="text-danger">*</span>
                    </label>
                    <InputText id="DescriptionCard"
                               @bind-Value="therapyCard.DescriptionCard"
                               class="form-control"
                               placeholder="Короткий опис..." />
                    <ValidationMessage For="@(() => therapyCard.DescriptionCard)" class="shine-edit-cosmo-error" />
                </div>

                <div class="form-group">
                    <label for="Price" class="form-label">
                        Ціна за послугу <span class="text-danger">*</span>
                    </label>
                    <div class="price-input">
                        <span class="price-symbol" aria-hidden="true">₴</span>
                        <InputNumber id="Price"
                                     @bind-Value="therapyCard.Price"
                                     class="form-control"
                                     placeholder="0" />
                    </div>
                    <span class="add-card-hint">Вкажіть вартість у гривнях.</span>
                    <ValidationMessage For="@(() => therapyCard.Price)" class="shine-edit-cosmo-error" />
                </div>

                <div class="form-group">
                    <label class="form-label">
                        Вибрати категорію для сторінки <span class="text-danger">*</span>
                    </label>
                    @if (!string.IsNullOrEmpty(ErrorMessageCategory))
                    {
                        <p class="shine-edit-cosmo-error mb-0">@ErrorMessageCategory</p>
                    }
                    <InputSelect class="form-select" TValue="int" @bind-Value="therapyCard.CategoryId">
                        <option value="0">Оберіть категорію</option>
                        @foreach (var item in categories)
                        {
                            <option value="@item.Id">@item.NameCategory</option>
                        }
                    </InputSelect>
                </div>

                <div class="form-group">
                    <label for="ImageUrl" class="form-label">Посилання на відео (YouTube ID)</label>
                    <InputText id="ImageUrl"
                               @bind-Value="therapyCard.ImagePath"
                               class="form-control"
                               placeholder="Вставте ID відео YouTube" />
                    <span class="add-card-hint">Тільки ідентифікатор відео, без повного URL.</span>
                    @if (!string.IsNullOrEmpty(therapyCard.ImagePath))
                    {
                        <div class="shine-edit-cosmo-video-preview ratio ratio-16x9 mt-3">
                            <lite-youtube videoid="@therapyCard.ImagePath" title="@therapyCard.TitleCard"></lite-youtube>
                        </div>
                    }
                </div>
            </div>

            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <p class="shine-edit-cosmo-error mt-3 mb-0">@ErrorMessage</p>
            }

            <div class="form-actions">
                @if (therapyCard.Id > 0)
                {
                    <button type="button"
                            class="btn-delete-card"
                            @onclick="() => DeleteTherapyCardAsync(therapyCard.Id)">
                        <i class="bi bi-trash" aria-hidden="true"></i>
                        <span class="d-none d-sm-inline">Видалити</span>
                    </button>
                }
                <button type="submit" class="btn-save">
                    <i class="bi bi-save" aria-hidden="true"></i>
                    <span class="d-none d-sm-inline">Зберегти</span>
                </button>
                <button type="button"
                        class="btn-cancel"
                        @onclick="CancelTherapyCard">
                    <i class="bi bi-x-circle" aria-hidden="true"></i>
                    <span class="d-none d-sm-inline">Скасувати</span>
                </button>
            </div>
        </EditForm>
    </section>

    <section class="shine-edit-cosmo-grid-section">
        <h3 class="shine-edit-cosmo-grid-title">
            <i class="bi bi-grid-3x3-gap" aria-hidden="true"></i>
            Картки послуг
        </h3>
        <div class="row g-3">
            @{
                var page = pageTherapies.FirstOrDefault(p => p.TitlePage == selectedMassage);
            }
            @foreach (var item in therapyCards.Where(x => x.CategoryId == page?.CategoryId))
            {
                <div class="col-6 col-lg-3">
                    <article class="shine-edit-cosmo-product h-100">
                        <div class="shine-edit-cosmo-product-image ratio ratio-16x9">
                            <lite-youtube videoid="@item.ImagePath" title="@item.TitleCard"></lite-youtube>
                        </div>
                        <div class="shine-edit-cosmo-product-body">
                            <h4 class="shine-edit-cosmo-product-title" title="@item.TitleCard">@item.TitleCard</h4>
                            <p class="shine-edit-cosmo-product-desc" title="@item.DescriptionCard">@item.DescriptionCard</p>
                            <div class="shine-edit-cosmo-product-footer">
                                <button type="button"
                                        class="shine-edit-cosmo-edit-btn"
                                        @onclick="() => EdittherapyCard(item.Id)">
                                    <i class="bi bi-pencil-square" aria-hidden="true"></i>
                                    Редагувати
                                </button>
                                <span class="shine-edit-cosmo-price">
                                    @item.Price.ToString("N0", new System.Globalization.CultureInfo("uk-UA")) ₴
                                </span>
                            </div>
                        </div>
                    </article>
                </div>
            }
        </div>
    </section>
</div>

@code {
    [Parameter]
    public int Id { get; set; }
    private string AddMessageTherapy = "Додати категорію";
    private TherapyCard therapyCard = new();

    private List<Category> categories = new();
    private List<PageTherapy> pageTherapies = new();
    private List<TherapyCard> therapyCards = new();

    private string ErrorMessageCategory = string.Empty;
    private string ErrorMessage = string.Empty;
    private string selectedMassage = "Масаж";

    protected override async Task OnInitializedAsync()
    {
        therapyCards = await _seedService.GetAllTherapyCardListAsync();
        pageTherapies = await _seedService.GetAllPageTherapyListAsync();
        categories = await _seedService.GetAllCategoryListAsync();

        if (Id > 0)
        {
            therapyCard = await _seedService.EditTherapyCard(Id);
            AddMessageTherapy = "Редагувати картку";
        }
    }

    private async Task SaveTherapyCardAsync()
    {
        if (string.IsNullOrWhiteSpace(therapyCard.TitleCard)
          || string.IsNullOrWhiteSpace(therapyCard.DescriptionCard)
          || therapyCard.Price <= 0
          || therapyCard.CategoryId == 0
          || string.IsNullOrWhiteSpace(therapyCard.ImagePath))
        {
            return;
        }

        await _seedService.SaveCosmetologyTherapyCardAsync(therapyCard);
        therapyCards = await _seedService.GetAllTherapyCardListAsync();
        therapyCard = new();
        StateHasChanged();
    }

    private async Task EdittherapyCard(int id)
    {
        therapyCard = await _seedService.EditTherapyCard(id);
        AddMessageTherapy = "Редагувати картку";
    }

    private async Task DeleteTherapyCardAsync(int cardId)
    {
        await _seedService.DeleteTherapyCardAsync(cardId);
        therapyCards = await _seedService.GetAllTherapyCardListAsync();
        therapyCard = new();
        StateHasChanged();
    }

    private void CancelTherapyCard()
    {
        therapyCard = new();
        StateHasChanged();
    }
}

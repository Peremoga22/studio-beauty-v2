@page "/admin-history-of-gift-sertificate-services"
@using System.Globalization
@using System.Threading.Tasks
@inject GiftCertificateService _giftCertificateService
@layout AdminLayout
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]

<div class="gift-page">
    <div class="gift-header">
        <div>
            <h1 class="gift-title">🎀 Історія створених подарункових сертифікатів</h1>
            <div class="gift-subtitle">
                Тут ви можете переглянути всі сертифікати та підтвердити їх.
            </div>
        </div>
        <div class="gift-count">Всього: <strong>@(Certificates?.Count ?? 0)</strong></div>
    </div>

    <nav class="gift-breadcrumb" aria-label="breadcrumb">
        Адміністративна панель / Історія створених подарункових сертифікатів
    </nav>

    @if (Certificates == null)
    {
        <div class="gift-state-loading" role="status">
            <div class="spinner-border spinner-border-sm me-2 text-secondary" aria-hidden="true"></div>
            Завантаження сертифікатів…
        </div>
    }
    else if (!Certificates.Any())
    {
        <div class="gift-state-empty">
            <p class="mb-1">Поки що немає створених подарункових сертифікатів.</p>
            <p class="small mb-0">Коли клієнти оформлять сертифікати — вони з’являться тут.</p>
        </div>
    }
    else
    {
        <div class="gift-grid">
            @foreach (var cert in Certificates)
            {
                <article class="gift-card">
                    <div class="gift-card-top">
                        <div>
                            <div class="gift-brand">SHINE COSMETOLOGY</div>
                            <div class="gift-small">Подарунковий сертифікат</div>
                        </div>
                        <div class="gift-card-top-meta">
                            @if (cert.IsApproved)
                            {
                                <span class="gift-status done">✅ Активовано</span>
                            }
                            else
                            {
                                <span class="gift-status wait">⏳ Очікує оплату</span>
                            }
                            <button type="button"
                                    class="gift-btn-delete"
                                    title="Видалити"
                                    aria-label="Видалити сертифікат"
                                    @onclick="() => DeleteGiftCertificate(cert.Id)">
                                🗑
                            </button>
                        </div>
                    </div>

                    <div class="gift-card-title">ПОДАРУНКОВИЙ СЕРТИФІКАТ</div>

                    <div class="gift-info">
                        <div class="gift-field-full">
                            <div class="gift-label">Отримувач</div>
                            <div class="gift-value">@cert.RecipientName</div>
                        </div>
                        <div>
                            <div class="gift-label">Сертифікат №</div>
                            <div class="gift-value">#@cert.Id</div>
                        </div>
                        <div>
                            <div class="gift-label">Номінал</div>
                            <div class="gift-price">@cert.Amount.ToString("N0", culture) грн</div>
                        </div>
                        <div>
                            <div class="gift-label">Термін дії</div>
                            <div class="gift-value">3 місяці</div>
                        </div>
                        <div>
                            <div class="gift-label">Створено</div>
                            <div class="gift-value">@cert.CreatedAt.ToString("dd.MM.yyyy")</div>
                        </div>
                        <div class="gift-field-full">
                            <div class="gift-label">Замовник</div>
                            <div class="gift-value">@cert.ClientName</div>
                        </div>
                        <div class="gift-field-full">
                            <div class="gift-label">Телефон замовника</div>
                            <div class="gift-value">@cert.ClientPhone</div>
                        </div>
                    </div>

                    <div class="gift-actions">
                        <div class="gift-id">ID: @cert.Id</div>
                        <div class="gift-btns">
                            <button type="button"
                                    class="gift-btn gift-btn-pdf"
                                    @onclick="() => DownloadPdf(cert.Id)">
                                ⬇ PDF
                            </button>
                            @if (!cert.IsApproved)
                            {
                                <button type="button"
                                        class="gift-btn gift-btn-pay"
                                        @onclick="() => OnCertificateClick(cert.Id)">
                                    Підтвердити оплату
                                </button>
                            }
                            else
                            {
                                <button type="button"
                                        class="gift-btn gift-btn-paid"
                                        disabled>
                                    Оплачено
                                </button>
                            }
                        </div>
                    </div>
                </article>
            }
        </div>
    }
</div>

@code {
    private static readonly CultureInfo culture = CultureInfo.GetCultureInfo("uk-UA");

    public List<GiftCertificateWithClientDto> Certificates { get; set; } = new();
    private Appointment appointment = new();

    protected override async Task OnInitializedAsync()
    {
        Certificates = await _giftCertificateService.GetGiftCertificatesAll();
    }

    private async Task OnCertificateClick(int id)
    {
        await _giftCertificateService.ApproveGiftCertificateAsync(id);
        Certificates = await _giftCertificateService.GetGiftCertificatesAll();
    }

    private async Task DeleteGiftCertificate(int id)
    {
        await _giftCertificateService.DeleteGiftCertificateAsync(id);
        Certificates = await _giftCertificateService.GetGiftCertificatesAll();
    }

    private async Task DownloadPdf(int id)
    {
        await _giftCertificateService.DownloadGiftCertificatePdfAsync(id, appointment);
    }
}

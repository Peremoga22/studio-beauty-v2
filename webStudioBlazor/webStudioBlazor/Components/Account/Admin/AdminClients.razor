@page "/admin-clients"
@using Microsoft.AspNetCore.Authorization
@using webStudioBlazor.Components.Layout
@inject AuthenticationStateProvider Auth
@inject SeedService _seedService
@layout AdminLayout
@using System.Globalization
@inject NavigationManager _navigationManager
@inject IJSRuntime JS
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer

<div class="container shine-admin-3d-page pb-4">
    <header class="shine-admin-page-hero text-center text-lg-start mb-4">
        <span class="shine-admin-page-kicker">Календар</span>
        <h1 class="shine-admin-page-title mb-0">Записи клієнтів</h1>
        <p class="shine-admin-page-lead mb-0 mt-2">Керуйте записами в преміум-інтерфейсі студії SHINE.</p>
    </header>

    <section class="card card--elevated shine-admin-3d-glass shine-admin-3d-glass--lift">
        <header class="card__header shine-admin-card-header">
            <div>
                <h2 class="title shine-admin-card-title">Календар записів</h2>
                <p class="subtitle shine-admin-card-subtitle">Оберіть день і перегляньте всі записи за послугами</p>
            </div>
        </header>

        <div class="divider shine-admin-divider"></div>

        <section aria-label="Список записів" class="cards shine-admin-entry-grid">
            @if (rows.Count == 0)
            {
                <div class="text-muted py-3">Немає записів</div>
            }
            else
            {
                @foreach (var row in rows)
                {
                    <article class="entry shine-admin-entry">
                        <div class="entry__row">
                            <span class="badge badge--massage">
                                @row.CategoryName
                            </span>

                            <span class="time">
                                @($"{row.Time:HH\\:mm} – {row.Time.AddMinutes(60):HH\\:mm}")
                            </span>
                        </div>

                        <div class="text-end">
                            <span>@row.Date.ToString("dd.MM.yyyy")</span>
                        </div>

                        <div class="client">
                            <strong>@row.ClientName</strong>
                        </div>

                        <div class="client">
                            <strong>
                                <a href="tel:@row.ClientPhone">@row.ClientPhone</a>
                            </strong>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(row.ServiceName))
                        {
                            <div class="procedure">@row.ServiceName</div>
                            <div class="meta">
                                @if (row.Price.HasValue)
                                {
                                    <span class="duration">
                                        @row.Price.Value.ToString("C0", ua)
                                    </span>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="procedure text-muted">Послуга не знайдена</div>
                        }

                        <div class="ms-auto text-left">
                            <button class="btn btn-outline-danger btn-sm rounded-pill d-inline-flex align-items-center gap-1"
                                    title="Видалити картку"
                                    disabled="@deleting.Contains(row.Id)"
                                    @onclick="() => ConfirmAndDeleteAsync(row)">
                                <i class="fa-solid fa-trash" aria-hidden="true"></i>
                                <span>@(deleting.Contains(row.Id) ? "Видаляю..." : "Видалити")</span>
                            </button>
                            <button class="btn btn-outline-info btn-sm rounded-pill d-inline-flex align-items-center gap-1" @onclick="() => OpenTreatmentHistory(row)">
                               Карта клієнта
                            </button>
                        </div>
                    </article>
                }

            }
        </section>
    </section>
</div>



@code {
    private List<CalendarRowDto> rows = new();
    private Appointment clientUser = new();
    private List<Appointment> clientList = new();
    private List<Master> masters = new();
    private List<Category> categories = new();
    private List<TherapyCard> therapyCards = new();
    private static readonly CultureInfo ua = new("uk-UA");
    private HashSet<int> deleting = new();

    protected override async Task OnInitializedAsync()
    {        
        var state = await Auth.GetAuthenticationStateAsync();
        var user = state.User;

        if (user.IsInRole("Admin"))
        {           
            rows = await _seedService.ListForCalendarForAdminAsync(onlyCompleted: true);
        }
        else if (user.IsInRole("Manicure"))
        {
            
            rows = await _seedService.ListManicureCalendarForManicureAsync(onlyCompleted: true);
        }       
    }
    private void OpenTreatmentHistory(CalendarRowDto row)
    {
        var clientKey = !string.IsNullOrEmpty(row.UserId) ? row.UserId! : $"guest:{row.AppointmentId}";
        _navigationManager.NavigateTo($"/admin/treatment-history/{Uri.EscapeDataString(clientKey)}");
    }

    private async Task ConfirmAndDeleteAsync(CalendarRowDto row)
    {
        if (row is null) return;

        var message =
            $"Ви дійсно хочете видалити запис?\n\n" +
            $"Клієнт: {row.ClientName}\n" +
            $"Дата: {row.Date:dd.MM.yyyy}\n\n" +
            "Якщо це остання послуга в цьому візиті, буде також видалено пов’язану медичну історію та фото з картки клієнта.\n\n" +
            $"❗ Цю дію неможливо скасувати.";

        var confirmed = await JS.InvokeAsync<bool>("confirm", message);

        if (!confirmed)
            return;

        deleting.Add(row.Id);
        try
        {
            await _seedService.DeleteAdminClientCardAsync(row.Id);
            rows.RemoveAll(r => r.Id == row.Id);
            StateHasChanged();
        }
        finally
        {
            deleting.Remove(row.Id);
        }
    }

}

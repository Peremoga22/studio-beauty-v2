@page "/admin-our-reviews-for-stududia"
@using webStudioBlazor.Data
@using System.Security.Claims
@inject SeedService _seedService
@inject NavigationManager NavigationManager
@layout AdminLayout
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]

<div class="container shine-admin-3d-page pb-4">
    <header class="shine-admin-page-hero text-center text-lg-start mb-4">
        <span class="shine-admin-page-kicker">Відгуки</span>
        <h1 class="shine-admin-page-title mb-0">Відгуки про нас</h1>
        <p class="shine-admin-page-lead mb-0 mt-2">Переглядайте та керуйте відгуками клієнтів студії SHINE.</p>
    </header>

    <div class="reviews-card">
        @if (reviews == null)
        {
            <p class="shine-admin-reviews-loading mb-0">Завантаження…</p>
        }
        else if (!reviews.Any())
        {
            <div class="shine-admin-reviews-empty rounded-4 p-4 text-center">
                Поки немає відгуків
            </div>
        }
        else
        {
            <div class="shine-admin-reviews-banner" role="status">
                <span class="shine-admin-reviews-banner-text">
                    <i class="bi bi-chat-heart me-2" aria-hidden="true"></i>
                    Відгуки клієнтів після візитів та покупок у магазині
                </span>
                <i class="bi bi-shield-check shine-admin-reviews-banner-icon" aria-hidden="true"></i>
            </div>

            <div class="reviews-list">
                @foreach (var r in reviews)
                {
                    <article class="review-item shine-admin-review-entry">
                        <div class="review-item__body">
                            <p class="shine-admin-review-name mb-2 text-center mb-md-0 text-md-start">
                                @(r.Appointment?.ClientName ?? "Клієнт")
                            </p>

                            <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start gap-2 mb-2">
                                <h2 class="shine-admin-review-service mb-0">
                                    @(r.TherapyCard?.TitleCard ?? "Послуга")
                                </h2>
                                <time class="shine-admin-review-date" datetime="@r.CreatedAt.ToString("o")">
                                    @r.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")
                                </time>
                            </div>

                            <div class="shine-admin-review-stars mb-2" aria-label="Оцінка @r.Rating з 5">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <i class="@(i <= r.Rating ? "fa-solid" : "fa-regular") fa-star" aria-hidden="true"></i>
                                }
                            </div>

                            @if (!string.IsNullOrWhiteSpace(r.Comment))
                            {
                                <p class="shine-admin-review-comment mb-2">@r.Comment</p>
                            }

                            <p class="shine-admin-review-master mb-0">
                                <i class="bi bi-person-badge me-1" aria-hidden="true"></i>
                                Майстер: <strong>@(r.Master?.FullName ?? "—")</strong>
                            </p>
                        </div>

                        <div class="review-item__actions">
                            <button type="button"
                                    class="btn btn-outline-danger btn-sm rounded-pill d-inline-flex align-items-center gap-1 px-3 py-1 shine-admin-review-delete-btn"
                                    title="Видалити відгук"
                                    @onclick="() => DeleteReview(r.Id)">
                                <i class="fa-solid fa-trash" aria-hidden="true"></i>
                                <span>Видалити</span>
                            </button>
                        </div>
                    </article>
                }
            </div>
        }
    </div>
</div>

@code {
    private List<Review> reviews = new();

    protected override async Task OnInitializedAsync()
    {
        reviews = await _seedService.GetAllReviewsForUserAsync();
    }

    private async Task DeleteReview(int reviewId)
    {
        await _seedService.DeleteReviewAsync(reviewId);
        reviews = await _seedService.GetAllReviewsForUserAsync();
    }
}

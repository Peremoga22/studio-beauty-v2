@page "/admin-seed"
@using Microsoft.AspNetCore.Authorization
@using webStudioBlazor.Components.Layout
@using webStudioBlazor.EntityModels
@using webStudioBlazor.Services
@inject SeedService _seedService
@layout AdminLayout
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]

<div class="container shine-admin-3d-page pb-4">
    <header class="shine-admin-page-hero text-center text-lg-start mb-4">
        <span class="shine-admin-page-kicker">Контент сайту</span>
        <h1 class="shine-admin-page-title mb-0">Наповнення послуг</h1>
        <p class="shine-admin-page-lead mb-0 mt-2">
            Переглядайте майстрів, категорії та титулки сторінок SHINE.
        </p>
    </header>

    <nav class="shine-admin-cosmo-breadcrumb mb-4" aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item active" aria-current="page">
                <i class="bi bi-database me-1" aria-hidden="true"></i>
                Категорії та дані
            </li>
        </ol>
    </nav>

    <div class="clients-card shine-admin-cosmo-card">
        <div class="shine-admin-cosmo-toolbar">
            <div class="shine-admin-cosmo-toolbar-title">
                <i class="bi bi-folder-plus" aria-hidden="true"></i>
                <span>Категорії</span>
            </div>
            <NavLink class="shine-admin-cosmo-btn shine-admin-cosmo-btn--primary text-decoration-none"
                     href="/edit-seed">
                <i class="bi bi-plus-lg" aria-hidden="true"></i>
                <span>Додати наповнення даних</span>
            </NavLink>
        </div>

        <h3 class="shine-admin-seed-section-title">Майстри</h3>
        <div class="table-responsive shine-admin-cosmo-table-wrap shine-admin-seed-table-block">
            <table class="table shine-admin-cosmo-table align-middle mb-0">
                <thead>
                    <tr>
                        <th scope="col">Назва категорії</th>
                        <th scope="col" class="text-end"></th>
                    </tr>
                </thead>
                <tbody>
                    @if (masters == null || masters.Count == 0)
                    {
                        <tr>
                            <td colspan="2" class="shine-admin-cosmo-empty text-center py-4">
                                Немає записів.
                                <span class="shine-admin-seed-empty-accent">Додайте дані через «Додати наповнення даних».</span>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in masters)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex flex-column">
                                        <span class="shine-admin-cosmo-name">@item.FullName</span>
                                        <small class="text-muted">@item.Phone</small>
                                    </div>
                                </td>
                                <td></td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <h3 class="shine-admin-seed-section-title">Категорії послуг</h3>
        <div class="table-responsive shine-admin-cosmo-table-wrap shine-admin-seed-table-block">
            <table class="table shine-admin-cosmo-table align-middle mb-0">
                <thead>
                    <tr>
                        <th scope="col">Назва категорії</th>
                        <th scope="col" class="text-end"></th>
                    </tr>
                </thead>
                <tbody>
                    @if (categories == null || categories.Count == 0)
                    {
                        <tr>
                            <td colspan="2" class="shine-admin-cosmo-empty text-center py-4">
                                Немає жодної категорії.
                                <span class="shine-admin-seed-empty-accent">Додайте через «Додати наповнення даних».</span>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in categories)
                        {
                            <tr>
                                <td class="shine-admin-cosmo-name">@item.NameCategory</td>
                                <td></td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <h3 class="shine-admin-seed-section-title">Титулки сторінок</h3>
        <div class="table-responsive shine-admin-cosmo-table-wrap">
            <table class="table shine-admin-cosmo-table align-middle mb-0">
                <thead>
                    <tr>
                        <th scope="col">Назва категорії</th>
                        <th scope="col" class="text-end"></th>
                    </tr>
                </thead>
                <tbody>
                    @if (pageTherapies == null || pageTherapies.Count == 0)
                    {
                        <tr>
                            <td colspan="2" class="shine-admin-cosmo-empty text-center py-4">
                                Немає записів.
                                <span class="shine-admin-seed-empty-accent">Додайте через «Додати наповнення даних».</span>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in pageTherapies)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex flex-column">
                                        <span class="shine-admin-cosmo-name">@item.TitlePage</span>
                                        <small class="text-muted">@item.DescriptionPage</small>
                                    </div>
                                </td>
                                <td></td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private List<Master> masters = new();
    private List<Category> categories = new();
    private List<PageTherapy> pageTherapies = new();

    protected override async Task OnInitializedAsync()
    {
        masters = await _seedService.GetAllMasterListAsync();
        categories = await _seedService.GetAllCategoryListAsync();
        pageTherapies = await _seedService.GetAllPageTherapyListAsync();
    }
}

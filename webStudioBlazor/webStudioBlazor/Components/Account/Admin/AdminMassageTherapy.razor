@page "/admin-massage-therapy"

@inject SeedService _seedService
@inject NavigationManager _navigationManager
@layout AdminLayout
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer

<div class="container shine-admin-3d-page pb-4">
    <header class="shine-admin-page-hero text-center text-lg-start mb-4">
        <span class="shine-admin-page-kicker">Контент сайту</span>
        <h1 class="shine-admin-page-title mb-0">Наповнення: масажна терапія</h1>
        <p class="shine-admin-page-lead mb-0 mt-2">
            Керуйте титулкою та описом сторінки масажу SHINE.
        </p>
    </header>

    <nav class="shine-admin-cosmo-breadcrumb mb-4" aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item active" aria-current="page">
                <i class="bi bi-hand-index-thumb me-1" aria-hidden="true"></i>
                Масаж
            </li>
        </ol>
    </nav>

    <div class="clients-card shine-admin-cosmo-card">
        <div class="shine-admin-cosmo-toolbar">
            <div class="shine-admin-cosmo-toolbar-title">
                <i class="bi bi-card-image" aria-hidden="true"></i>
                <span>Титулка сторінки масаж</span>
            </div>
            <NavLink class="shine-admin-cosmo-btn shine-admin-cosmo-btn--primary text-decoration-none"
                     href="/edit-massage-therapy">
                <i class="bi bi-plus-lg" aria-hidden="true"></i>
                <span>Додати титулку</span>
            </NavLink>
        </div>

        <div class="table-responsive shine-admin-cosmo-table-wrap">
            <table class="table shine-admin-cosmo-table align-middle mb-0">
                <thead>
                    <tr>
                        <th scope="col">Назва</th>
                        <th scope="col">Опис</th>
                        <th scope="col" class="text-end">Дії</th>
                    </tr>
                </thead>
                <tbody>
                    @if (pageTherapyList is null || pageTherapyList.Count == 0)
                    {
                        <tr>
                            <td colspan="3" class="shine-admin-cosmo-empty text-center py-5">
                                Нічого не знайдено.
                                <NavLink class="shine-admin-cosmo-link ms-1" href="/edit-massage-therapy">
                                    Додайте першу титулку
                                </NavLink>
                            </td>
                        </tr>
                    }
                    else
                    {
                        var page = pageTherapyList.FirstOrDefault(p => p.TitlePage == selectedMassage);
                        @foreach (var item in pageTherapyList.Where(x => x.CategoryId == page?.CategoryId))
                        {
                            <tr>
                                <td class="shine-admin-cosmo-name">
                                    <span class="cell-truncate" title="@item.TitlePage">@item.TitlePage</span>
                                </td>
                                <td class="shine-admin-cosmo-desc">@item.DescriptionPage</td>
                                <td class="text-end">
                                    <NavLink class="shine-admin-cosmo-edit-btn text-decoration-none"
                                             href="@($"/edit-massage-therapy/{item.Id}")">
                                        <i class="bi bi-pencil-square" aria-hidden="true"></i>
                                        <span class="d-none d-sm-inline">Редагувати</span>
                                    </NavLink>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private List<PageTherapy> pageTherapyList = new();
    private string selectedMassage = "Масаж";

    protected override async Task OnInitializedAsync()
    {
        pageTherapyList = await _seedService.GetAllPageTherapyListAsync();
    }
}

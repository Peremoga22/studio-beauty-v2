@page "/admin-category"

@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using webStudioBlazor.Components.Layout
@using webStudioBlazor.EntityModels
@using webStudioBlazor.Services
@inject SeedService _seedService
@layout AdminLayout
@attribute [Authorize(Roles = "Admin")]

<div class="container shine-admin-3d-page pb-4">
    <header class="shine-admin-page-hero text-center text-lg-start mb-4">
        <span class="shine-admin-page-kicker">Контент сайту</span>
        <h1 class="shine-admin-page-title mb-0">Наповнення послуг</h1>
        <p class="shine-admin-page-lead mb-0 mt-2">
            Керуйте категоріями послуг студії SHINE.
        </p>
    </header>

    <nav class="shine-admin-cosmo-breadcrumb mb-4" aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item active" aria-current="page">
                <i class="bi bi-tags me-1" aria-hidden="true"></i>
                Категорії
            </li>
        </ol>
    </nav>

    <div class="clients-card shine-admin-cosmo-card">
        <div class="shine-admin-cosmo-toolbar">
            <div class="shine-admin-cosmo-toolbar-title">
                <i class="bi bi-folder-plus" aria-hidden="true"></i>
                <span>Категорії</span>
            </div>
            <NavLink class="shine-admin-cosmo-btn shine-admin-cosmo-btn--primary text-decoration-none"
                     href="/edit-category">
                <i class="bi bi-plus-lg" aria-hidden="true"></i>
                <span>Додати категорію</span>
            </NavLink>
        </div>

        <div class="table-responsive shine-admin-cosmo-table-wrap">
            <table class="table shine-admin-cosmo-table align-middle mb-0">
                <thead>
                    <tr>
                        <th scope="col">Назва категорії</th>
                        <th scope="col" class="text-end">Дії</th>
                    </tr>
                </thead>
                <tbody>
                    @if (categories == null || categories.Count == 0)
                    {
                        <tr>
                            <td colspan="2" class="shine-admin-cosmo-empty text-center py-5">
                                Немає жодної категорії.
                                <span class="shine-admin-empty-hint">Натисніть «Додати категорію».</span>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in categories)
                        {
                            <tr>
                                <td class="shine-admin-cosmo-name">@item.NameCategory</td>
                                <td class="text-end">
                                    <div class="d-flex flex-wrap justify-content-end gap-2">
                                        <NavLink class="shine-admin-cosmo-edit-btn text-decoration-none"
                                                 href="@($"/edit-category/{item.Id}")">
                                            <i class="bi bi-pencil-square" aria-hidden="true"></i>
                                            <span class="d-none d-sm-inline">Редагувати</span>
                                        </NavLink>
                                        <button type="button"
                                                class="btn btn-outline-danger btn-sm rounded-pill"
                                                @onclick="() => Delete(item.Id)">
                                            <i class="bi bi-trash" aria-hidden="true"></i>
                                            <span class="d-none d-sm-inline">Видалити</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private List<Category> categories = new();

    protected override async Task OnInitializedAsync()
    {
        categories = await _seedService.GetAllCategoryListAsync();
    }

    protected async Task Delete(int categoryId)
    {
        await _seedService.DeleteCategoryAsync(categoryId);
        categories = await _seedService.GetAllCategoryListAsync();
    }
}

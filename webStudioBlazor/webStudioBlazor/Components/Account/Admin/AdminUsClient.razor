@page "/admin-us-clients"

@inject AuthenticationStateProvider Auth
@inject NavigationManager _navigationManager
@inject SeedService _seedService
@layout AdminLayout
@attribute [Authorize(Roles = "Admin,Manicure")]
@rendermode InteractiveServer

<div class="container shine-admin-3d-page pb-4">
    <header class="shine-admin-page-hero text-center text-lg-start mb-4">
        <span class="shine-admin-page-kicker">База клієнтів</span>
        <h1 class="shine-admin-page-title mb-0">Клієнти</h1>
        <p class="shine-admin-page-lead mb-0 mt-2">
            Пошук, перегляд і редагування записів клієнтів студії SHINE.
        </p>
    </header>

    <div class="clients-card shine-admin-clients-card">
        <div class="shine-admin-clients-toolbar">
            <div class="shine-admin-clients-toolbar-title">
                <i class="bi bi-people-fill" aria-hidden="true"></i>
                <span>Записи клієнтів</span>
            </div>
            <div class="shine-admin-clients-filters">
                <div class="shine-admin-clients-search-wrap">
                    <label class="shine-admin-clients-label" for="clients-search">Пошук (ім’я / телефон)</label>
                    <input id="clients-search"
                           type="search"
                           class="form-control shine-admin-clients-input"
                           placeholder="Введіть ім’я або телефон…"
                           @bind="search"
                           @bind:event="oninput"
                           @onkeydown="OnSearchKeyDown" />
                </div>
                <div class="shine-admin-clients-actions">
                    <button type="button"
                            class="shine-admin-clients-btn shine-admin-clients-btn--primary"
                            @onclick="Search">
                        <i class="bi bi-search" aria-hidden="true"></i>
                        Пошук
                    </button>
                    <button type="button"
                            class="shine-admin-clients-btn shine-admin-clients-btn--ghost"
                            @onclick="Reset">
                        <i class="bi bi-arrow-counterclockwise" aria-hidden="true"></i>
                        Скинути
                    </button>
                </div>
            </div>
        </div>

        <div class="table-responsive shine-admin-clients-table-wrap">
            <table class="table shine-admin-clients-table align-middle mb-0">
                <thead>
                    <tr>
                        <th scope="col">Дата</th>
                        <th scope="col">Час</th>
                        <th scope="col">Ім’я</th>
                        <th scope="col">Телефон</th>
                        <th scope="col" class="d-none d-md-table-cell">Категорія</th>
                        <th scope="col">Послуга</th>
                        <th scope="col">Ціна</th>
                        <th scope="col" class="text-center">Дії</th>
                    </tr>
                </thead>
                <tbody>
                    @if (pagedRows.Count == 0)
                    {
                        <tr>
                            <td colspan="8" class="shine-admin-clients-empty text-center py-5">
                                Нічого не знайдено
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var r in pagedRows)
                        {
                            <tr>
                                <td class="text-nowrap">@r.Date.ToString("dd.MM.yyyy")</td>
                                <td class="text-nowrap">@r.Time.ToString("HH\\:mm")</td>
                                <td class="shine-admin-clients-name">@r.Name</td>
                                <td>
                                    <a href="tel:@r.Phone" class="shine-admin-clients-phone">@r.Phone</a>
                                </td>
                                <td class="d-none d-md-table-cell">@r.Category</td>
                                <td>@r.Service</td>
                                <td class="shine-admin-clients-price text-nowrap">
                                    @r.Price.ToString("C0", ua)
                                </td>
                                <td class="text-center">
                                    <button type="button"
                                            class="btn btn-outline-danger btn-sm rounded-pill shine-admin-clients-edit-btn"
                                            title="Редагувати"
                                            @onclick="() => EditRow(r.Id)">
                                        <i class="bi bi-pencil-square" aria-hidden="true"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <footer class="shine-admin-clients-footer">
            <p class="shine-admin-clients-meta mb-0">
                Показано <strong>@pagedRows.Count</strong> з <strong>@filteredRows.Count</strong> записів
                @if (totalPages > 1)
                {
                    <span class="shine-admin-clients-meta-sep">·</span>
                    <span>Сторінка @currentPage з @totalPages</span>
                }
            </p>
            <div class="shine-admin-clients-pager" role="navigation" aria-label="Пагінація">
                <button type="button"
                        class="shine-admin-clients-pager-btn"
                        @onclick="PrevPage"
                        disabled="@IsFirstPage"
                        aria-label="Попередня сторінка">
                    «
                </button>
                <span class="shine-admin-clients-pager-current" aria-current="page">@currentPage / @totalPages</span>
                <button type="button"
                        class="shine-admin-clients-pager-btn"
                        @onclick="NextPage"
                        disabled="@IsLastPage"
                        aria-label="Наступна сторінка">
                    »
                </button>
            </div>
        </footer>
    </div>
</div>

@code {
    private List<Appointment> allClientList = new();
    private List<Category> categories = new();
    private List<TherapyCard> therapyCards = new();

    private readonly CultureInfo ua = new("uk-UA");
    private string? search;

    private int currentPage = 1;
    private const int pageSize = 10;

    private List<RowVM> filteredRows = new();
    private List<RowVM> pagedRows = new();
    private int totalPages;
    private bool IsFirstPage => currentPage <= 1;
    private bool IsLastPage => currentPage >= totalPages;
    private bool _isAdmin;
    private bool _isManicure;

    protected override async Task OnInitializedAsync()
    {
        var state = await Auth.GetAuthenticationStateAsync();
        var user = state.User;

        _isAdmin = user.IsInRole("Admin");
        _isManicure = user.IsInRole("Manicure");

        allClientList = await _seedService.GetAllClientListAsync();
        categories = await _seedService.GetAllCategoryListAsync();
        therapyCards = await _seedService.GetAllTherapyCardListAsync();

        Rebuild();
    }

    private void Rebuild()
    {
        filteredRows = GetAllRows();
        totalPages = Math.Max(1, (int)Math.Ceiling(filteredRows.Count / (double)pageSize));
        currentPage = Math.Clamp(currentPage, 1, totalPages);
        pagedRows = filteredRows.Skip((currentPage - 1) * pageSize).Take(pageSize).ToList();
    }

    private void PrevPage()
    {
        if (!IsFirstPage)
        {
            currentPage--;
            Rebuild();
        }
    }

    private void NextPage()
    {
        if (!IsLastPage)
        {
            currentPage++;
            Rebuild();
        }
    }

    private void Search()
    {
        currentPage = 1;
        Rebuild();
    }

    private async Task Reset()
    {
        search = string.Empty;
        currentPage = 1;
        allClientList = await _seedService.GetAllClientListAsync();
        categories = await _seedService.GetAllCategoryListAsync();
        therapyCards = await _seedService.GetAllTherapyCardListAsync();
        Rebuild();
    }

    private void OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            Search();
        }
    }

    private List<RowVM> GetAllRows()
    {
        var rows = from a in (allClientList ?? Enumerable.Empty<Appointment>())
                   let cat = categories.FirstOrDefault(c => c.Id == a.CategoryId)
                   let th = therapyCards.FirstOrDefault(t => t.Id == a.TherapyId)
                   select new RowVM(
                       a.Id,
                       a.ClientName ?? "",
                       a.ClientPhone ?? "",
                       a.AppointmentDate,
                       a.SetHour,
                       cat?.NameCategory ?? "—",
                       th?.TitleCard ?? "—",
                       a.IsCompleted,
                       a.Price);

        if (_isManicure && !_isAdmin)
        {
            rows = rows.Where(r => r.Category == "Манікюр");
        }

        if (!string.IsNullOrWhiteSpace(search))
        {
            var s = search.Trim().ToLowerInvariant();
            rows = rows.Where(r =>
                r.Name.ToLowerInvariant().Contains(s) ||
                r.Phone.ToLowerInvariant().Contains(s) ||
                r.Service.ToLowerInvariant().Contains(s));
        }

        return rows
            .OrderByDescending(r => r.Date)
            .ThenByDescending(r => r.Time)
            .ToList();
    }

    private void EditRow(int id)
    {
        _navigationManager.NavigateTo($"/edit-client/{id}");
    }

    private sealed record RowVM(
        int Id,
        string Name,
        string Phone,
        DateOnly Date,
        TimeOnly Time,
        string Category,
        string Service,
        bool Completed,
        decimal Price);
}

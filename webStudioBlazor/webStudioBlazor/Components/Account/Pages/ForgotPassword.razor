@page "/Account/ForgotPassword"

@using System.ComponentModel.DataAnnotations
@using System.Net
@using Microsoft.AspNetCore.Identity
@using webStudioBlazor.Data
@using webStudioBlazor.Services

@inject UserManager<ApplicationUser> UserManager
@inject IEmailService EmailService
@inject NavigationManager NavigationManager
@inject IdentityRedirectManager RedirectManager
@inject ILogger<ForgotPassword> Logger

<PageTitle>Відновлення пароля</PageTitle>

<section class="shine-login-page">
    <div class="shine-login-inner">
        <nav class="shine-login-breadcrumb mb-4" aria-label="Навігаційна стежка">
            <a href="/" class="shine-login-breadcrumb-link">Домашня сторінка</a>
            <span class="shine-login-breadcrumb-sep" aria-hidden="true">/</span>
            <a class="shine-login-breadcrumb-link" href="/Account/Login">Вхід</a>
            <span class="shine-login-breadcrumb-sep" aria-hidden="true">/</span>
            <span class="shine-login-breadcrumb-current">Забули пароль</span>
        </nav>

        <div class="row justify-content-center g-0">
            <div class="col-12">
                <div class="card shine-login-card border-0 shadow-none">
                    <div class="card-body p-4 p-md-5">
                        <h1 class="shine-login-card-title text-center h2 mb-2">Відновлення пароля</h1>
                        <p class="shine-login-card-lead text-center mb-4">
                            Введіть email облікового запису — якщо він існує, надішлемо посилання для нового пароля.
                        </p>

                        <EditForm Model="Input" FormName="forgot-password" OnValidSubmit="OnValidSubmitAsync" method="post">
                            <DataAnnotationsValidator />
                            <ValidationSummary class="text-danger mb-3" role="alert" />

                            <div class="form-floating mb-3">
                                <InputText @bind-Value="Input.Email" id="forgot-email" class="form-control" autocomplete="username" placeholder="name@example.com" />
                                <label for="forgot-email">Електронна пошта</label>
                                <ValidationMessage For="() => Input.Email" class="text-danger small" />
                            </div>

                            <button type="submit" class="shine-hero-btn shine-login-submit border-0 w-100">Надіслати посилання</button>
                        </EditForm>

                        <p class="text-center mt-4 mb-0 shine-login-card-lead">
                            Повернутися до
                            <a class="shine-login-breadcrumb-link" href="/Account/Login">входу</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@code {
    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    private async Task OnValidSubmitAsync()
    {
        var email = Input.Email.Trim();
        var user = await UserManager.FindByEmailAsync(email);

        if (user is not null)
        {
            try
            {
                var token = await UserManager.GeneratePasswordResetTokenAsync(user);
                var encodedToken = WebUtility.UrlEncode(token);
                var baseUri = NavigationManager.BaseUri.TrimEnd('/');
                var resetLink = $"{baseUri}/Account/ResetPassword?email={Uri.EscapeDataString(email)}&token={encodedToken}";

                var html = $@"
<h2>Відновлення пароля</h2>
<p>Ви надіслали запит на відновлення пароля на сайті SHINE Cosmetology.</p>
<p>Щоб створити новий пароль, перейдіть за посиланням:</p>
<p><a href=""{resetLink}"">Відновити пароль</a></p>
<p>Якщо ви не надсилали цей запит, просто проігноруйте лист.</p>";

                await EmailService.SendEmailAsync(
                    email,
                    "Відновлення пароля SHINE Cosmetology",
                    html);
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Не вдалося надіслати лист відновлення пароля на {Email}.", email);
            }
        }

        RedirectManager.RedirectTo("Account/ForgotPasswordConfirmation");
    }

    private sealed class InputModel
    {
        [Required(ErrorMessage = "Вкажіть email.")]
        [EmailAddress(ErrorMessage = "Некоректний формат email.")]
        public string Email { get; set; } = "";
    }
}

@page "/Account/ForgotPassword"

@using System.ComponentModel.DataAnnotations
@using System.Text
@using System.Text.Encodings.Web
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.WebUtilities
@using webStudioBlazor.Data

@inject UserManager<ApplicationUser> UserManager
@inject IEmailSender<ApplicationUser> EmailSender
@inject NavigationManager NavigationManager
@inject IdentityRedirectManager RedirectManager

<PageTitle>Відновлення пароля</PageTitle>

<section class="shine-login-page">
    <div class="shine-login-inner">
        <nav class="shine-login-breadcrumb mb-4" aria-label="Навігаційна стежка">
            <a href="/" class="shine-login-breadcrumb-link">Домашня сторінка</a>
            <span class="shine-login-breadcrumb-sep" aria-hidden="true">/</span>
            <a class="shine-login-breadcrumb-link" href="/Account/Login">Вхід</a>
            <span class="shine-login-breadcrumb-sep" aria-hidden="true">/</span>
            <span class="shine-login-breadcrumb-current">Забули пароль</span>
        </nav>

        <div class="row justify-content-center g-0">
            <div class="col-12">
                <div class="card shine-login-card border-0 shadow-none">
                    <div class="card-body p-4 p-md-5">
                        <h1 class="shine-login-card-title text-center h2 mb-2">Відновлення пароля</h1>
                        <p class="shine-login-card-lead text-center mb-4">
                            Введіть email облікового запису — надішлемо посилання для створення нового пароля.
                        </p>

                        <EditForm Model="Input" FormName="forgot-password" OnValidSubmit="OnValidSubmitAsync" method="post">
                            <DataAnnotationsValidator />
                            <ValidationSummary class="text-danger mb-3" role="alert" />

                            <div class="form-floating mb-3">
                                <InputText @bind-Value="Input.Email" id="forgot-email" class="form-control" autocomplete="username" placeholder="name@example.com" />
                                <label for="forgot-email">Електронна пошта</label>
                                <ValidationMessage For="() => Input.Email" class="text-danger small" />
                            </div>

                            <button type="submit" class="shine-hero-btn shine-login-submit border-0 w-100">Надіслати посилання</button>
                        </EditForm>

                        <p class="text-center mt-4 mb-0 shine-login-card-lead">
                            Повернутися до
                            <a class="shine-login-breadcrumb-link" href="/Account/Login">входу</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@code {
    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    private async Task OnValidSubmitAsync()
    {
        var user = await UserManager.FindByEmailAsync(Input.Email);
        if (user is null)
        {
            RedirectManager.RedirectTo("Account/ForgotPasswordConfirmation");
        }
        else
        {
            var code = await UserManager.GeneratePasswordResetTokenAsync(user);
            code = WebEncoders.Base64UrlEncode(Encoding.UTF8.GetBytes(code));
            var callbackUrl = NavigationManager.GetUriWithQueryParameters(
                NavigationManager.ToAbsoluteUri("Account/ResetPassword").AbsoluteUri,
                new Dictionary<string, object?> { ["code"] = code, ["email"] = user.Email });

            await EmailSender.SendPasswordResetLinkAsync(user, Input.Email, HtmlEncoder.Default.Encode(callbackUrl));

            RedirectManager.RedirectTo("Account/ForgotPasswordConfirmation");
        }
    }

    private sealed class InputModel
    {
        [Required(ErrorMessage = "Вкажіть email.")]
        [EmailAddress(ErrorMessage = "Некоректний формат email.")]
        public string Email { get; set; } = "";
    }
}

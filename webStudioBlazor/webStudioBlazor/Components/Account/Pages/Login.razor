@page "/Account/Login"

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Identity
@using webStudioBlazor.Components.Account.Admin
@using webStudioBlazor.Data

@inject SignInManager<ApplicationUser> SignInManager
@inject ILogger<Login> Logger
@inject NavigationManager NavigationManager
@inject IdentityRedirectManager RedirectManager
@inject UserManager<ApplicationUser> UserManager
@inject IConfiguration Configuration
@inject IJSRuntime _jsRuntime


<PageTitle>Вхід</PageTitle>

<section class="shine-login-page">
    <div class="shine-login-inner">
        <nav class="shine-login-breadcrumb mb-4" aria-label="Навігаційна стежка">
            <a href="/" class="shine-login-breadcrumb-link">Домашня сторінка</a>
            <span class="shine-login-breadcrumb-sep" aria-hidden="true">/</span>
            <span class="shine-login-breadcrumb-current">Вхід</span>
        </nav>

        <div class="row justify-content-center g-0">
            <div class="col-12">
                <div class="card shine-login-card border-0 shadow-none">
                    <div class="card-body p-4 p-md-5">

                        <h1 class="shine-login-card-title text-center h2 mb-2">Вітаю!</h1>
                        <p class="shine-login-card-lead text-center mb-4">Введіть, будь ласка, електронну пошту та пароль.</p>

                        <StatusMessage Message="@errorMessage" />

                        <EditForm Model="Input" method="post" OnValidSubmit="LoginUser" FormName="login">
                            <DataAnnotationsValidator />
                            <ValidationSummary class="text-danger mb-3" />

                            <div class="form-floating mb-3">
                                <InputText @bind-Value="Input.Email"
                                           id="login-email"
                                           class="form-control"
                                           autocomplete="username"
                                           placeholder="name@example.com" />
                                <label for="login-email">Електронна пошта</label>
                                <ValidationMessage For="() => Input.Email" class="text-danger small" />
                            </div>

                            <div class="form-floating mb-3">
                                <InputText @bind-Value="Input.Password"
                                           id="login-password"
                                           type="password"
                                           class="form-control"
                                           autocomplete="current-password"
                                           placeholder="password" />
                                <label for="login-password">Пароль</label>
                                <ValidationMessage For="() => Input.Password" class="text-danger small" />
                            </div>

                            <div class="form-check mb-4">
                                <InputCheckbox @bind-Value="Input.RememberMe"
                                               id="RememberMe"
                                               class="form-check-input" />
                                <label for="RememberMe" class="form-check-label">Запам'ятати мене</label>
                            </div>

                            <button type="submit" class="shine-hero-btn shine-login-submit border-0 mb-0">Логін</button>

                            <div class="d-flex flex-column flex-sm-row justify-content-between align-items-center gap-2 mt-4 text-center text-sm-start">
                               @*  <a class="shine-login-breadcrumb-link small text-decoration-none" href="/Account/ForgotPassword">Забули пароль?</a> *@
                                <a class="shine-login-breadcrumb-link small text-decoration-none" href="@RegisterHref">Ще не маєте акаунта? Зареєструватися</a>
                            </div>
                        </EditForm>

                        @if (ExternalLogins is { Count: > 0 })
                        {
                            <hr class="shine-login-divider" />
                            <p class="shine-login-external-caption">Або</p>
                        }
                        <ExternalLoginPicker />
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@code {
    private string? errorMessage;

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    private string? adminEmail;
    private IList<AuthenticationScheme>? ExternalLogins { get; set; }
    private string SafeReturnUrl => GetSafeReturnUrl(ReturnUrl);

    private string RegisterHref =>
        NavigationManager.GetUriWithQueryParameters("Account/Register", new Dictionary<string, object?> { ["ReturnUrl"] = ReturnUrl });

    protected override async Task OnInitializedAsync()
    {
        adminEmail = Configuration.GetValue<string>("Admin:Login");
        if (HttpMethods.IsGet(HttpContext.Request.Method))
        {
            // Clear the existing external cookie to ensure a clean login process
            await HttpContext.SignOutAsync(IdentityConstants.ExternalScheme);
        }

        ExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync())?.ToList();
    }

    private void LoginWithGoogle()
    {
        var returnUrl = "/";
        NavigationManager.NavigateTo($"/auth/login-google?returnUrl={Uri.EscapeDataString(returnUrl)}", forceLoad: true);
    }

    private async Task Logout()
    {
        await _jsRuntime.InvokeVoidAsync("fetch", "/auth/logout", new
        {
            method = "POST",
            headers = new Dictionary<string, object> { { "X-Requested-With", "XMLHttpRequest" } }
        });

        NavigationManager.NavigateTo("/", true);
    }

    public async Task LoginUser()
    {
        // This doesn't count login failures towards account lockout
        // To enable password failures to trigger account lockout, set lockoutOnFailure: true
        var result = await SignInManager.PasswordSignInAsync(Input.Email, Input.Password, Input.RememberMe, lockoutOnFailure: false);

        if (result.Succeeded)
        {
            if (string.Equals(Input.Email, adminEmail, StringComparison.OrdinalIgnoreCase))
            {
                Logger.LogInformation("Admin logged in.");
                RedirectManager.RedirectTo("/admin-clients");
            }

            Logger.LogInformation("User logged in.");
            RedirectManager.RedirectTo(SafeReturnUrl);
        }
        else if (result.RequiresTwoFactor)
        {
            RedirectManager.RedirectTo(
                "Account/LoginWith2fa",
                new() { ["returnUrl"] = ReturnUrl, ["rememberMe"] = Input.RememberMe });
        }
        else if (result.IsLockedOut)
        {
            Logger.LogWarning("User account locked out.");
            RedirectManager.RedirectTo("Account/Lockout");
        }
        else
        {
            errorMessage = "Невірна електронна пошта або пароль.";
        }
    }

    private string GetSafeReturnUrl(string? candidate)
    {
        const string fallback = "/";
        return IsLocalUrl(NavigationManager, candidate) ? candidate! : fallback;
    }

    private static bool IsLocalUrl(NavigationManager nav, string? url)
    {
        if (string.IsNullOrWhiteSpace(url)) return false;

        var isAbsolute = Uri.TryCreate(url, UriKind.Absolute, out var abs);
        if (isAbsolute) return false;
        return true;
    }

    private sealed class InputModel
    {
        [Required]
        [EmailAddress]
        public string Email { get; set; } = "";

        [Required]
        [DataType(DataType.Password)]
        public string Password { get; set; } = "";

        [Display(Name = "Remember me?")]
        public bool RememberMe { get; set; }
    }
}

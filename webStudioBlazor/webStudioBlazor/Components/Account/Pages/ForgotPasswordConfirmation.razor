@page "/Account/ForgotPasswordConfirmation"

<PageTitle>Лист надіслано</PageTitle>

<section class="shine-login-page">
    <div class="shine-login-inner">
        <div class="card shine-login-card border-0 shadow-none">
            <div class="card-body p-4 p-md-5 text-center">
                <h1 class="shine-login-card-title h3 mb-3">Перевірте пошту</h1>
                <p class="shine-login-card-lead mb-4" role="status">
                    Якщо такий email існує, посилання для відновлення пароля буде надіслано.
                </p>
                <a class="shine-hero-btn shine-login-submit border-0 text-decoration-none d-inline-flex" href="/Account/Login">До входу</a>
            </div>
        </div>
    </div>
</section>
